   796                        ;**************************************************************************************************
   797                        ;START OF PANIC ROUTINE
   798                        ;The Panic routine is for debug of system problems, i.e., a crash. The hardware design requires a
   799                        ; debounced NMI trigger button which is manually operated when the system crashes or malfunctions.
   800                        ;
   801                        ;User presses the NMI (panic) button. The NMI vectored routine will perform the following tasks:
   802                        ; 1- Save CPU registers in page zero locations
   803                        ; 2- Reset the MicroDrive and disable interrupts
   804                        ; 3- Clear all Console I/O buffer pointers
   805                        ; 4- Call the ROM routines to init the vectors and config data (page $02)
   806                        ; 5- Call the ROM routines to reset/init the DUART (SC28L92)
   807                        ; 6- Enter the Monitor via the warm start vector **
   808                        ;
   809                        ; Note: The additional hardware detection (RTC/IDE) are NOT executed with the Panic routine!
   810                        ; The interrupt vectors are restored without including the additional ISR for the IDE controller.
   811                        ; The Microdrive Reset_Off command is also set to disable any bus activity.
   812                        ;
   813                        ; Note: no memory is cleared except the required pointers/vectors to restore the system.
   814                        ;
   815 00:FA66: 78           NMI_VECTOR      SEI                     ;Disable interrupts (2)
   816 00:FA67: 85 D8                        STA     AREG            ;Save A Reg (3)
   817 00:FA69: 86 D7                        STX     XREG            ;Save X Reg (3)
   818 00:FA6B: 84 D6                        STY     YREG            ;Save Y Reg (3)
   819 00:FA6D: 68                           PLA                     ;Get Processor Status (4)
   820 00:FA6E: 85 D4                        STA     PREG            ;Save in PROCESSOR STATUS preset/result (3)
   821 00:FA70: BA                           TSX                     ;Get Stack pointer (4)
   822 00:FA71: 86 D5                        STX     SREG            ;Save STACK POINTER (3)
   823 00:FA73: 68                           PLA                     ;Pull RETURN address from STACK (4)
   824 00:FA74: 85 D2                        STA     PCL             ;Store Low byte (3)
   825 00:FA76: 68                           PLA                     ;Pull high byte (4)
   826 00:FA77: 85 D3                        STA     PCH             ;Store High byte (3)
   827                        ;
   828 00:FA79: A9 06                        LDA     #%00000110      ;Get mask for MicroDrive Reset/IRQ disable (2)
   829 00:FA7B: 8D 36 FE                     STA     IDE_DEV_CTRL    ;Send to MicroDrive (4)
   830                        ;
   831 00:FA7E: 9C 05 FE                     STZ     UART_IMR        ;Disable ALL interrupts from UART (4)
   832                        ;
   833 00:FA81: A2 0C                        LDX     #$0C            ;Set count for 12 (2)
   834 00:FA83: 74 D8        PAN_LP1         STZ     ICNT_A-1,X      ;Clear DUART I/O pointers (3)
   835 00:FA85: CA                           DEX                     ;Decrement index (2)
  Sat Apr  4 2026 16:30                                                                                                    Page 21


   836 00:FA86: D0 FB                        BNE     PAN_LP1         ;Branch back till done (2/3)
   837                        ;
   838 00:FA88: 20 9C FF                     JSR     INIT_PG02       ;Xfer default Vectors/HW Config to $0200 (6)
   839 00:FA8B: 20 23 FA                     JSR     INIT_IO         ;Reset and Init the UART for Console (6)
   840                        ;
   841 00:FA8E: A9 02                        LDA     #%00000010      ;Get mask for MicroDrive Reset off (2)
   842 00:FA90: 8D 36 FE                     STA     IDE_DEV_CTRL    ;Send to MicroDrive (4)
   843                        ;
   844 00:FA93: 6C 06 02                     JMP     (NMIRTVEC0)     ;Jump to NMI Return Vector (Monitor Warm Start) (6)
