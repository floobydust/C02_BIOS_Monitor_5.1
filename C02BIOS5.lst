   713                        ;**************************************************************************************************
   714                        ;Initializing the SC28L92 DUART as a Console.
   715                        ;An anomaly in the W65C02 processor requires a different approach in programming the SC28L92
   716                        ; for proper setup/operation. The SC28L92 uses three Mode Registers which are accessed at the same
   717                        ; register in sequence. There is a command that Resets the Mode Register pointer (to MR0) that is
   718                        ; issued first. Then MR0/1/2 are loaded in sequence. The problem with the W65C02 is a false read of
   719                        ; the register when using indexed addressing (i.e., STA UART_REGISTER,X). This results in the Mode
   720                        ; Register pointer being moved to the next register, so the write to next MRx never happens. While
   721                        ; the indexed list works fine for all other register functions/commands, the loading of the
   722                        ; Mode Registers need to be handled separately.
   723                        ;
   724                        ;NOTE: the W65C02 will function normally "if" a page boundary is crossed as part of the STA
   725                        ; (i.e., STA $FDFF,X) where the value of the X Register is high enough to cross the page boundary.
   726                        ; Programming in this manner would be confusing and require modification if the base I/O address
   727                        ; is changed for a different hardware I/O map.
   728                        ;
   729                        ;There are two routines called to setup the 28L92 DUART:
   730                        ;
   731                        ;The first routine is a RESET of the DUART.
   732                        ; It issues the following sequence of commands:
   733                        ;  1- Reset Break Change Interrupts
   734                        ;  2- Reset Receivers
   735                        ;  3- Reset Transmitters
   736                        ;  4- Reset All errors
   737                        ;
   738                        ;The second routine initializes the 28L92 DUART for operation. It uses two tables of data; one for
   739                        ; the register offset and the other for the register data. The table for register offsets is
   740                        ; maintained in ROM. The table for register data is copied to page $02, making it soft data. If
   741                        ; needed, operating parameters can be altered and the DUART re-initialized via the ROM routine.
   742                        ;
   743                        ; Note: A hardware reset will reset the SC28L92 and the default ROM config will be initialized.
   744                        ; Also note that the Panic routine invoked by a NMI trigger will also reset the DUART to the
   745                        ; default ROM config.
   746                        ;
   747 00:FA23: 20 57 FA     INIT_IO         JSR     RESET_28L92     ;Reset the SC28L92 DUART (both channels) (6)
   748 00:FA26: A9 64                        LDA     #DF_TICKS       ;Get divider for jiffy clock (100x10ms = 1 second) (2)
   749 00:FA28: 85 E6                        STA     TICKS           ;Preload TICK count (3)
   750                        ;
   751                        ;This routine sets the initial operating mode of the DUART
   752                        ;
   753 00:FA2A: 78           INIT_28L92      SEI                     ;Disable interrupts (2)
   754                        ;
   755 00:FA2B: A2 0F                        LDX     #INIT_DUART_E-INIT_DUART ;Get the Init byte count (2)
   756 00:FA2D: BD 1F 02     28L92_INT       LDA     LOAD_28L92-1,X  ;Get Data for 28L92 Register (4)
   757 00:FA30: BC 84 FE                     LDY     INIT_OFFSET-1,X ;Get Offset for 28L92 Register (4)
   758 00:FA33: 99 00 FE                     STA     SC28L92_BASE,Y  ;Store Data to selected register (5)
   759 00:FA36: CA                           DEX                     ;Decrement count (2)
   760 00:FA37: D0 F4                        BNE     28L92_INT       ;Loop back until all registers are loaded (2/3)
   761                        ;
   762                        ; Mode Registers are NOT reset to MR0 by above INIT_28L92!
   763                        ; The following resets the MR pointers for both channels, then sets the MR registers
   764                        ; for each channel. Note: the MR index is incremented to the next location after the write.
   765                        ; NOTE: These writes can NOT be done via indexed addressing modes!
   766                        ;
   767 00:FA39: A9 B0                        LDA     #%10110000      ;Get mask for MR0 Reset (2)
   768 00:FA3B: 8D 02 FE                     STA     UART_COMMAND_A  ;Reset Pointer for Port A (4)
   769 00:FA3E: 8D 0A FE                     STA     UART_COMMAND_B  ;Reset Pointer for Port B (4)
   770                        ;
   771 00:FA41: A2 03                        LDX     #$03            ;Set index for 3 bytes to xfer (2)
   772 00:FA43: BD 2F 02     MR_LD_LP        LDA     LOAD_28L92+15,X ;Get MR data for Port A (4)
  Sat Apr  4 2026 16:30                                                                                                    Page 20


   773 00:FA46: 8D 00 FE                     STA     UART_MODEREG_A  ;Send to 28L92 Port A (4)
   774 00:FA49: BD 32 02                     LDA     LOAD_28L92+18,X ;Get MR data for Port B (4)
   775 00:FA4C: 8D 08 FE                     STA     UART_MODEREG_B  ;Send to 28L92 Port B (4)
   776 00:FA4F: CA                           DEX                     ;Decrement index to next data (2)
   777 00:FA50: D0 F1                        BNE     MR_LD_LP        ;Branch back till done (2/3)
   778                        ;
   779 00:FA52: 58                           CLI                     ;Enable interrupts (2)
   780                        ;
   781                        ; Start Counter/Timer
   782                        ;
   783 00:FA53: AD 0E FE                     LDA     UART_START_CNT  ;Read register to start counter/timer (4)
   784 00:FA56: 60                           RTS                     ;Return to caller (6)
   785                        ;
   786                        ; This routine does a Reset of the SC28L92 - both channels
   787                        ;
   788 00:FA57: A2 04        RESET_28L92     LDX     #UART_RDATAE-UART_RDATA1 ;Get the Reset commands byte count (2)
   789 00:FA59: BD 80 FE     UART_RES1       LDA     UART_RDATA1-1,X ;Get Reset commands (4)
