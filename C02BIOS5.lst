   115             000000EC   SETMS           .EQU    BIOS_PG0+44             ;Set timeout for delay routines - BIOS use only
   116             000000ED   DELLO           .EQU    BIOS_PG0+45             ;Delay value BIOS use only
   117             000000EE   DELHI           .EQU    BIOS_PG0+46             ;Delay value BIOS use only
