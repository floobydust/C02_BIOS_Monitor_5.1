   543                        ;**************************************************************************************************
   544                        ;Delay Routines: SET_DLY sets up the MSDELAY value and also sets the 16-bit Long Delay
   545                        ; On entry, A Reg = 10-millisecond count, X Reg = High multiplier, Y Reg = Low multiplier
   546                        ; these values are used by the EXE_MSDLY and EXE_LGDLY routines. Minimum delay is 10ms
   547                        ; values for MSDELAY are $00-$FF ($00 = 256 times)
   548                        ; values for Long Delay are $0000-$FFFF (0-65535 times MSDELAY)
   549                        ; longest delay is 65,535*256*10ms = 16,776,960 * 0.01 = 167,769.60 seconds
   550                        ;
   551                        ;NOTE: All delay execution routines preserve registers (EXE_MSDLY, EXE_LGDLY)
   552                        ;
   553 00:F982: 85 EC        SET_DLY         STA     SETMS           ;Save Millisecond count (3)
   554 00:F984: 84 ED                        STY     DELLO           ;Save Low multiplier (3)
   555 00:F986: 86 EE                        STX     DELHI           ;Save High multiplier (3)
   556 00:F988: 60                           RTS                     ;Return to caller (6)
   557                        ;
   558                        ;EXE MSDELAY routine is the core delay routine. It sets the MSDELAY count value from the
   559                        ; SETMS variable, enables the MATCH flag, then waits for the MATCH flag to clear.
   560                        ;
   561 00:F989: 48           EXE_MSDLY       PHA                     ;Save A Reg (3)
   562 00:F98A: F7 FF                        SMB7    MATCH           ;Set MATCH flag bit (5)
   563 00:F98C: A5 EC                        LDA     SETMS           ;Get delay seed value (3)
   564 00:F98E: 85 EB                        STA     MSDELAY         ;Set MS delay value (3)
   565                        ;
   566 00:F990: FF FF FD     MATCH_LP        BBS7    MATCH,MATCH_LP  ;Test MATCH flag, loop until cleared (5/6,7)
   567 00:F993: 68                           PLA                     ;Restore A Reg (4)
   568 00:F994: 60                           RTS                     ;Return to caller (6)
   569                        ;
   570                        ;EXE LONG Delay routine is the 16-bit multiplier for the MSDELAY routine.
   571                        ; It loads the 16-bit count from DELLO/DELHI, then loops the MSDELAY routine
   572                        ; until the 16-bit count is decremented to zero.
   573                        ;
   574 00:F995: DA           EXE_LGDLY       PHX                     ;Save X Reg (3)
   575 00:F996: 5A                           PHY                     ;Save Y Reg (3)
   576 00:F997: A6 EE                        LDX     DELHI           ;Get high byte count (3)
   577 00:F999: E8                           INX                     ;Increment by one (checks for $00 vs $FF) (2)
   578 00:F99A: A4 ED                        LDY     DELLO           ;Get low byte count (3)
   579 00:F99C: F0 06                        BEQ     SKP_DLL         ;If zero, skip to high count (2/3)
   580 00:F99E: 20 89 F9     DO_DLL          JSR     EXE_MSDLY       ;Call millisecond delay (6)
   581 00:F9A1: 88                           DEY                     ;Decrement low count (2)
   582 00:F9A2: D0 FA                        BNE     DO_DLL          ;Branch back until done (2/3)
   583                        ;
