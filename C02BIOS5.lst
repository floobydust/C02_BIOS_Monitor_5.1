   584 00:F9A4: CA           SKP_DLL         DEX                     ;Decrement high byte index (2)
   585 00:F9A5: D0 F7                        BNE     DO_DLL          ;Loop back to D0_DLL (will run 256 times) (2/3)
   586 00:F9A7: 7A                           PLY                     ;Restore Y Reg (4)
   587 00:F9A8: FA                           PLX                     ;Restore X Reg (4)
   588 00:F9A9: 60                           RTS                     ;Return to caller (6)
   589                        ;
   590                        ;**************************************************************************************************
   591                        ;COUNTER BENCHMARK TIMING ROUTINES
   592                        ; To enable some basic benchmarking, the following routines are part of C02BIOS version 5.x
   593                        ;
   594                        ; - CNT_INIT is used to zero the timing variables
   595                        ; - CNT_STRT is used to start the timing by setting bit 6 of the MATCH flag
   596                        ; - CNT_STOP is used to stop the timing by clearing bit 6 of the MATCH flag
   597                        ; - CNT_DISP is used to display the benchmark counter output (also stops the timing)
   598                        ;
   599                        ; Using the existing 10ms Jiffy Clock, three bytes of Page zero are used to hold variables;
   600                        ; - MS10_CNT - a 10ms count variable for 0.01 resolution of timing - resets at 100 counts (1 second)
   601                        ; - SECL_CNT - a low byte seconds count
   602                        ; - SECH_CNT - a high byte seconds count
   603                        ; This provides up to 65,535.99 seconds of timing with 0.01 seconds resolution
   604                        ; - NOTE: the count variables reset to zero after 65,535.99 seconds!
   605                        ;
   606                        ; The interrupt handler for the DUART timer increments the timing variables when bit 6 of the
   607                        ; MATCH flag is active.
   608                        ;
   609 00:F9AA: 67 FF        CNT_INIT        RMB6    MATCH           ;Clear bit 6 of MATCH flag, ensure timing is disabled (5)
   610 00:F9AC: 64 EF                        STZ     MS10_CNT        ;Zero 10ms timing count (3)
   611 00:F9AE: 64 F0                        STZ     SECL_CNT        ;Zero low byte of seconds timing count (3)
   612 00:F9B0: 64 F1                        STZ     SECH_CNT        ;Zero high byte of seconds timing count (3)
   613 00:F9B2: 60                           RTS                     ;Return to caller (6)
   614                        ;
   615 00:F9B3: E7 FF        CNT_STRT        SMB6    MATCH           ;Set bit 6 of MATCH flag to enable timing (5)
   616 00:F9B5: 60                           RTS                     ;Return to caller (6)
   617                        ;
   618 00:F9B6: 67 FF        CNT_STOP        RMB6    MATCH           ;Clear bit 6 of MATCH flag to disable timing (5)
   619 00:F9B8: 60                           RTS                     ;Return to caller (6)
   620                        ;
   621                        ;Display Benchmark timer:
   622                        ; Benchmark timer is stopped by clearing bit 6 of MATCH flag. Once the Benchmark counter is
   623                        ; stopped, the HEX2ASC routine prints the 16-bit seconds count, followed by a period,
   624                        ; then the HEX8ASC routine prints the hundreds count followed by the "Seconds" message.
   625                        ;
   626 00:F9B9: 67 FF        CNT_DISP        RMB6    MATCH           ;Stop Benchmark Counter (5)
   627 00:F9BB: A5 F0                        LDA     SECL_CNT        ;Get seconds low count (3)
   628 00:F9BD: A4 F1                        LDY     SECH_CNT        ;Get seconds high count (3)
   629 00:F9BF: 20 E5 F9                     JSR     HEX2ASC         ;Print 16-bit decimal value (6)
   630                        ;
   631 00:F9C2: A9 2E                        LDA     #"."            ;Get period character (2)
   632 00:F9C4: 20 1C F8                     JSR     CHROUT          ;Send "." to console (6)
   633 00:F9C7: A5 EF                        LDA     MS10_CNT        ;Get hundreds of seconds (3)
   634                        ;
   635                        ; Drop into HEX8ASC
   636                        ;
   637                        ;HEX8ASC - Accepts 8-bit Hexadecimal value (00-99 decimal) and converts to ASCII numeric values.
   638                        ; A Register contains the single byte value on entry and outputs the two ASCII numeric values.
   639                        ; leading zero is output as it is used for showing hundredths of a second after a decimal point.
   640 00:F9C9: A0 FF        HEX8ASC         LDY     #$FF            ;Load Y Reg with "-1" (2)
   641 00:F9CB: 38                           SEC                     ;Set carry for subtraction (2)
   642 00:F9CC: C8           HEX8LP1         INY                     ;Increment 10's count (starts at zero) (2)
   643 00:F9CD: E9 0A                        SBC     #10             ;Subtract 10 decimal (2)
   644 00:F9CF: B0 FB                        BCS     HEX8LP1         ;Branch back if >10 (2/3)
   645 00:F9D1: 69 3A                        ADC     #$3A            ;Add the last 10 back plus $30 (ASCII "0") (2)
   646 00:F9D3: 48                           PHA                     ;Save 1's count to the Stack (3)
  Sat Apr  4 2026 16:30                                                                                                    Page 18


   647 00:F9D4: 98                           TYA                     ;Get the 10's count (2)
   648 00:F9D5: 18                           CLC                     ;Clear carry for add (2)
   649 00:F9D6: 69 30                        ADC     #$30            ;Add $30 for ASCII digit (3)
   650 00:F9D8: 20 1C F8                     JSR     CHROUT          ;Print the first digit (10's)
   651 00:F9DB: 68                           PLA                     ;Get 1's count from the Stack (4)
   652 00:F9DC: 20 1C F8                     JSR     CHROUT          ;Print the second digit, return (6)
   653                        ;
   654 00:F9DF: A9 F0                        LDA     #<MSG_SEC       ;Get message for " Seconds" (2)
   655 00:F9E1: A0 FE                        LDY     #>MSG_SEC       ; (2)
   656 00:F9E3: 80 2A        PRMPT_SC        BRA     PROMPTR         ;Send to console, return (3)
   657                        ;
   658                        ;HEX2ASC - Accepts 16-bit Hexadecimal value and converts to an ASCII decimal string. Input is
   659                        ; via the A and Y Registers and output is up to 5 ASCII digits in DATABUFF. The High Byte is in
   660                        ; the Y Register and Low Byte is in the A Register. Output data is placed in variable DATABUFF
   661                        ; and terminated with a null character.
   662                        ; Note: leading zeros are suppressed. PROMPTR routine is used to print the ASCII decimal value.
   663                        ; Core routine based on Michael Barry's code. Saves many bytes with two updates/changes ;-)
   664 00:F9E5: 85 CE        HEX2ASC         STA     BINVALL         ;Save Low byte (3)
   665 00:F9E7: 84 CF                        STY     BINVALH         ;Save High byte (3)
   666 00:F9E9: A2 05                        LDX     #5              ;Get ASCII buffer offset (2)
   667 00:F9EB: 74 C8                        STZ     DATABUFF,X      ;Zero last buffer byte for null end (4)
