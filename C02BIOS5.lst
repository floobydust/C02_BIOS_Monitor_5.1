   791 00:FA5F: 8D 0A FE                     STA     UART_COMMAND_B  ;Send to UART B CR (4)
   792 00:FA62: CA                           DEX                     ;Decrement the command list index (2)
   793 00:FA63: D0 F4                        BNE     UART_RES1       ;Loop back until all are sent (2/3)
   794 00:FA65: 60                           RTS                     ;Return to caller (6)
