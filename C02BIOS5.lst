   846                        ;**************************************************************************************************
   847                        ;BRK/IRQ Interrupt service routines
   848                        ;The pre-process routine located in page $FF soft-vectors to INTERUPT0/BRKINSTR0 below
   849                        ;       These are the routines that handle BRK and IRQ functions
   850                        ;       The BRK handler saves CPU details for register display
   851                        ;       - A Monitor can provide a disassembly of the last executed instruction
   852                        ;       - A Received Break is also handled here (ExtraPutty/Windows or Serial/OSX)
   853                        ;
   854                        ; SC28L92 handler
   855                        ;       The 28L92 IRQ routine handles Transmit, Receive, Timer and Received-Break interrupts
   856                        ;       - Transmit and Receive each have a 128 byte circular FIFO buffer in memory per channel
   857                        ;       - Xmit IRQ is controlled (On/Off) by the handler and the CHROUT(2) routine
   858                        ;
   859                        ; The 28L92 Timer resolution is 10ms and used as a Jiffy Clock for RTC, delays and benchmarking
   860                        ;**************************************************************************************************
   861                        ;BIOS routines to handle interrupt-driven I/O for the SC28L92
   862                        ; NOTE: IP0 Pin is used for RTS, which is automatically handled in the chip. As a result,
   863                        ; the upper 2 bits of the ISR are not used in the handler. The Lower 5 bits are used, but
   864                        ; the lower two are used to determine when to disable transmit after the buffer is empty.
   865                        ;
   866                        ;The DUART_ISR bits are defined as follows:
   867                        
   868                        ; Bit7          ;Input Change Interrupt
   869                        ; Bit6          ;Change Break B Interrupt
   870                        ; Bit5          ;RxRDY B Interrupt
   871                        ; Bit4          ;TxRDY B Interrupt
   872                        ; Bit3          ;Counter Ready Interrupt
   873                        ; Bit2          ;Change Break A Interrupt
   874                        ; Bit1          ;RxRDY A Interrupt
   875                        ; Bit0          ;TxRDY A Interrupt
   876                        ;
   877                        ; SC8L92 uses all bits in the Status Register!
   878                        ; - for Receive Buffer full, we set a bit in the SC28L92 Misc. Register, one for each Port.
   879                        ; Note that the Misc. Register in the SC28L92 is a free byte for storing the flags, as it's
   880                        ; not used when the DUART is configured in Intel mode! Freebie Register for us to use ;-)
   881                        ;
   882                        ; NOTE: The entry point for the BRK/IRQ handler is below at label INTERUPT0
   883                        ;**************************************************************************************************
   884                        ;ISR Routines for SC28L92 Port B
   885                        ;
   886                        ; The operation is the same as Port A below, sans the fact that the Break detection only resets
   887                        ; the DUART channel and returns, while Port A uses Break detection for other functions within
   888                        ; the BIOS structure, and processes the BRK routine shown further down.
   889                        ;
   890 00:FA96: A4 DF        UARTB_RCV       LDY     ICNT_B          ;Get input buffer count (3)
   891 00:FA98: 30 41                        BMI     BUFFUL_B        ;Check against limit ($80), branch if full (2/3)
   892                        ;
   893 00:FA9A: AD 09 FE     UARTB_RCVLP     LDA     UART_STATUS_B   ;Get Status Register (4)
   894 00:FA9D: 89 01                        BIT     #%00000001      ;Check RxRDY active (2)
   895 00:FA9F: F0 10                        BEQ     UARTB_CXMT      ;If RxRDY not set, FIFO is empty, check Xmit (2/3)
   896                        
   897 00:FAA1: AD 0B FE                     LDA     UART_RECEIVE_B  ;Else, get data from 28L92 (4)
   898 00:FAA4: A4 E1                        LDY     ITAIL_B         ;Get the tail pointer to buffer (3)
  Sat Apr  4 2026 16:30                                                                                                    Page 22


   899 00:FAA6: 99 00 04                     STA     IBUF_B,Y        ;Store into buffer (5)
   900 00:FAA9: E6 E1                        INC     ITAIL_B         ;Increment tail pointer (5)
   901 00:FAAB: 77 E1                        RMB7    ITAIL_B         ;Strip off bit 7, 128 bytes only (5)
   902 00:FAAD: E6 DF                        INC     ICNT_B          ;increment data count (5)
   903 00:FAAF: 10 E9                        BPL     UARTB_RCVLP     ;If input buffer not full, check for more FIFO data (2/3)
   904                        ;
   905 00:FAB1: AD 05 FE     UARTB_CXMT      LDA     UART_ISR        ;Get 28L92 ISR Reg (4)
   906 00:FAB4: 89 10                        BIT     #%00010000      ;Check for Xmit B active (2)
   907 00:FAB6: F0 20                        BEQ     REGEXT_B        ;Exit if inactive (2/3)
   908                        ;
   909                        ; To take advantage of the onboard FIFO, we test the TxRDY bit in the Status Register. If the
   910                        ; bit is set, then there is more room in the FIFO. The ISR routine here will attempt to fill
   911                        ; the FIFO from the Output Buffer. This saves processing time in the ISR itself.
   912                        ;
   913 00:FAB8: A5 E2        UARTB_XMT       LDA     OCNT_B          ;Get output buffer count, any data to xmit? (3)
   914 00:FABA: F0 17                        BEQ     NODATA_B        ;If zero, no data left, turn off xmit (2/3)
   915                        ;
   916 00:FABC: AD 09 FE     UARTB_XMTLP     LDA     UART_STATUS_B   ;Get Status Register (4)
   917 00:FABF: 89 04                        BIT     #%00000100      ;Check TxRDY active (2)
   918 00:FAC1: F0 15                        BEQ     REGEXT_B        ;If TxRDY not set, FIFO is full, exit ISR (2/3)
   919                        ;
   920 00:FAC3: A4 E3                        LDY     OHEAD_B         ;Get the head pointer to buffer (3)
   921 00:FAC5: B9 80 04                     LDA     OBUF_B,Y        ;Get the next data (4)
   922 00:FAC8: 8D 0B FE                     STA     UART_TRANSMIT_B ;Send the data to 28L92 (4)
   923 00:FACB: E6 E3                        INC     OHEAD_B         ;Increment head pointer (5)
   924 00:FACD: 77 E3                        RMB7    OHEAD_B         ;Strip off bit 7, 128 bytes only (5)
   925 00:FACF: C6 E2                        DEC     OCNT_B          ;Decrement counter (5)
   926 00:FAD1: D0 E9                        BNE     UARTB_XMTLP     ;If more data, loop back to send it (2/3)
   927                        ;
   928                        ;No more buffer data to send, check SC28L92 TxEMT and disable transmit if empty.
   929                        ; Note: If the TxEMT bit is set, then the FIFO is empty and all data has been sent.
   930                        ;
   931 00:FAD3: A0 08        NODATA_B        LDY     #%00001000      ;Else, get mask for xmit off (2)
   932 00:FAD5: 8C 0A FE                     STY     UART_COMMAND_B  ;Turn off xmit (4)
   933 00:FAD8: 6C 0A 02     REGEXT_B        JMP     (IRQRTVEC0)     ;Return to Exit/ROM IRQ handler (6)
   934                        ;
   935 00:FADB: A0 10        BUFFUL_B        LDY     #%00010000      ;Get Mask for Buffer full (2)
   936 00:FADD: 8C 0C FE                     STY     UART_MISC       ;Save into 28L92 Misc. Register (4)
   937 00:FAE0: 80 F6                        BRA     REGEXT_B        ;Exit IRQ handler (3)
   938                        ;
   939                        ;Received Break handler for Port B
   940                        ;
   941 00:FAE2: AD 09 FE     UARTB_BRK       LDA     UART_STATUS_B   ;Get DUART Status Register (4)
   942 00:FAE5: 30 0D                        BMI     BREAKEY_B       ;If bit 7 set, received Break was detected (2/3)
   943                        ;
   944                        ; If a received Break was not the cause, we should reset the DUART Port as the cause
   945                        ; could have been a receiver error, i.e., parity or framing
   946                        ;
   947 00:FAE7: A2 05                        LDX     #UART_RDATAE-UART_RDATA ;Get index count (2)
   948 00:FAE9: BD 7F FE     UARTB_RST1      LDA     UART_RDATA-1,X  ;Get Reset commands (4)
   949 00:FAEC: 8D 0A FE                     STA     UART_COMMAND_B  ;Send to DUART CR (4)
   950 00:FAEF: CA                           DEX                     ;Decrement the command list (2)
   951 00:FAF0: D0 F7                        BNE     UARTB_RST1      ;Loop back until all are sent (2/3)
   952 00:FAF2: 80 E4                        BRA     REGEXT_B        ;Exit (3)
   953                        ;
   954                        ; A received Break was the cause. Just reset the receiver and return.
   955                        ;
   956 00:FAF4: A9 40        BREAKEY_B       LDA     #%01000000      ;Get Reset Received Break command (2)
   957 00:FAF6: 8D 0A FE                     STA     UART_COMMAND_B  ;Send to DUART to reset (4)
   958 00:FAF9: A9 50                        LDA     #%01010000      ;Get Reset Break Interrupt command (2)
   959 00:FAFB: 8D 0A FE                     STA     UART_COMMAND_B  ;Send to DUART to reset (4)
   960 00:FAFE: 80 D8                        BRA     REGEXT_B        ;Exit (3)
