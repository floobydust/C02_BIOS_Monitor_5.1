   109             000000E8   SECS_1          .EQU    BIOS_PG0+40             ;Seconds: bits 8-15
   110             000000E9   SECS_2          .EQU    BIOS_PG0+41             ;Seconds: bits 16-23
   111             000000EA   SECS_3          .EQU    BIOS_PG0+42             ;Seconds: bits 24-31
   112                        ;
