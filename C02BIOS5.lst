  1880                        ;
  1881 00:FE70: 17           MR2_DAT_A       .DB     %00010111       ;Mode Register 2 data
  1882 00:FE71: D3           MR1_DAT_A       .DB     %11010011       ;Mode Register 1 Data
  1883 00:FE72: F9           MR0_DAT_A       .DB     %11111001       ;Mode Register 0 Data
  1884                        ;
  1885 00:FE73: 17           MR2_DAT_B       .DB     %00010111       ;Mode Register 2 data
  1886 00:FE74: D3           MR1_DAT_B       .DB     %11010011       ;Mode Register 1 Data
  1887 00:FE75: C1           MR0_DAT_B       .DB     %11000001       ;Mode Register 0 Data
