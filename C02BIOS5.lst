  1338 00:FCB7: E0 04                        CPX     #$04            ;Check for all 4 moved (2)
  1339 00:FCB9: D0 F6                        BNE     RTC_LOAD_LOOP   ;Loop back until done (2/3)
  1340                        ;
  1341 00:FCBB: A9 80                        LDA     #%10000000      ;Get TE Bit mask (2)
  1342 00:FCBD: 0C 2A FE                     TSB     RTC_CONTROL_A   ;Turn on TE Bit to enable update (6)
  1343 00:FCC0: 60           NO_RTC          RTS                     ;Return to caller (6)
  1344                        ;
  1345                        ;**************************************************************************************************
  1346                        ;
  1347                        ;This routine detects the IDE Port
  1348                        ; To detect the IDE controller, it can be a bit tricky. It might take several seconds from a
  1349                        ; physical Reset of the IDE Controller before the Busy flag goes off. During this time, any
  1350                        ; commands sent to the IDE controller will fail. As I like to say, "timing is everything". After
  1351                        ; quite a bit of testing, the easy way to detect the IDE controller present is to load the
  1352                        ; IDE_STATUS register. If an IDE Controller is not present, the A Reg will show a phantom address
  1353                        ; of $FE (high order IDE hardware address) and any initialization can be bypassed.
  1354                        ;
  1355                        ; If the IDE controller is present, the IDE_STATUS read may be invalid, so it's necessary
  1356                        ; to test the BUSY flag of the status register. Once the IDE Controller is no longer busy,
  1357                        ; the controller can be initialized. This does create an obvious pause in the startup, but
  1358                        ; ensures that the IDE controller can be reliably detected and initialized at boot time.
  1359                        ;
  1360                        ; As interrupts are disabled on the IDE Controller initially, it needs to be enabled before the
  1361                        ; setup is completed. A separate routine enables interrupts and is also called by the Reset-Diag
  1362                        ; function (JMP $FF00).
  1363                        ;
  1364                        DETECT_IDE
  1365 00:FCC1: AD 3F FE                     LDA     IDE_STATUS      ;Get the IDE Status (4)
  1366 00:FCC4: C9 FE                        CMP     #$FE            ;Check for an empty (phantom) address (2)
  1367 00:FCC6: D0 01                        BNE     IDE_INIT        ;If not #$FE, try to Init the IDE controller (2/3)
  1368 00:FCC8: 60                           RTS                     ;Else, return to caller, no IDE controller found (6)
  1369                        ;
  1370                        ;Init the IDE controller
  1371                        ; First, test for the IDE controller ready. If that works, execute the IDE device Diagnostics and
  1372                        ; check for successful completion. If it fails, exit without linking the IDE controller into the
  1373                        ; IRQ chain. Else, link IRQ chain and show message that the IDE device is found.
  1374                        ;
  1375                        IDE_INIT
  1376 00:FCC9: AD 36 FE                     LDA     IDE_ALT_STATUS  ;Get IDE Alternate Status register (4)
  1377 00:FCCC: 30 FB                        BMI     IDE_INIT        ;Loop until BUSY bit is clear (2/3)
  1378                        ;
  1379 00:FCCE: 20 6D FD                     JSR     IDE_DIAG        ;Run the self diagnostic (6)
  1380 00:FCD1: C9 50                        CMP     #$50            ;Check for $50 on A reg (drive ready) (2)
  1381 00:FCD3: D0 11                        BNE     NO_IDE          ;If not, no IDE present (2/3)
  1382 00:FCD5: E0 01                        CPX     #$01            ;X Reg will show #$01 if diags successful (2)
  1383 00:FCD7: D0 0D                        BNE     NO_IDE          ;If failed, exit (2/3)
  1384                        ;
  1385                        ; IDE Controller found and passed initial self diagnostics test.
  1386                        ; Send IDE Found message to terminal, note: X reg = $01.
  1387                        ;
  1388 00:FCD9: D7 FF                        SMB5    MATCH           ;Set Match Bit 5 for IDE present (5)
  1389 00:FCDB: BD BF FF     IDE_MSG_LP      LDA     IDE_MSG-1,X     ;Get BIOS init msg (minus 1 for X reg=1) (4)
  1390 00:FCDE: F0 09                        BEQ     IDE_SETUP       ;If zero, msg done, go setup IDE (2/3)
  1391 00:FCE0: 20 1C F8                     JSR     CHROUT          ;Send to console (6)
  1392 00:FCE3: E8                           INX                     ;Increment Index (2)
  1393 00:FCE4: 80 F5                        BRA     IDE_MSG_LP      ;Loop back until done (3)
  1394                        ;
  1395 00:FCE6: 4C 72 F9     NO_IDE          JMP     IDE_RD_ERR      ;Jump to drive error message (3)
  Sat Apr  4 2026 16:30                                                                                                    Page 30


  1396                        ;
  1397                        ;IDE Setup
  1398                        ; This will insert the IDE Controller ISR into the Interrupt Handler chain.
  1399                        ;
  1400                        ; First, disable interrupts, capture the current IRQ exit vector address
  1401                        ; and save it to the first Insert Vector. Second, load the IDE ISR routine
  1402                        ; address and store it to the main IRQ exit vector, then re-enable interrupts.
  1403                        ;
  1404                        ; Second, this routine will execute an Identify IDE command to load the Soft
  1405                        ; Config Data for the maximum LBA Count accessible by the current IDE device.
  1406                        ;
  1407                        ; Note: For performnce, the IDE ISR will be inserted before the DUART ISR!
  1408                        ;
  1409                        IDE_SETUP                               ;Insert IDE ISR into IRQ chain
  1410                        ;
  1411                        ; To load the IDE ISR Handler BEFORE the existing DUART ISR Handler:
  1412 00:FCE9: 78                           SEI                     ;Disable interrupts (2)
  1413                        ;
  1414 00:FCEA: AD 04 02                     LDA     IRQVEC0         ;Get low byte of current IRQ Exit (4)
  1415 00:FCED: AC 05 02                     LDY     IRQVEC0+1       ;Get high byte of current IRQ Exit (4)
  1416 00:FCF0: 8D 10 02                     STA     VECINSRT0       ;Save low byte of IRQ Exit to insert 0 (4)
  1417 00:FCF3: 8C 11 02                     STY     VECINSRT0+1     ;Save high byte of IRQ Exit to insert 0 (4)
  1418                        ;
  1419 00:FCF6: A9 99                        LDA     #<INTERUPT1     ;Get low byte of IDE ISR (2)
  1420 00:FCF8: A0 FD                        LDY     #>INTERUPT1     ;Get high byte of IDE ISR (2)
  1421 00:FCFA: 8D 04 02                     STA     IRQVEC0         ;Save low byte of IRQ Exit (4)
  1422 00:FCFD: 8C 05 02                     STY     IRQVEC0+1       ;Save high byte of IRQ Exit (4)
  1423                        ;
  1424 00:FD00: 58                           CLI                     ;Enable interrupts (2)
  1425 00:FD01: 20 90 FD                     JSR     IDE_EN_IRQ      ;Enable IDE Controller interrupt (6)
  1426                        ;
  1427                        ; Drop into Identify Drive routine
  1428                        ;
  1429                        IDE_IDENTIFY                            ;Identify Device
  1430                        ;
  1431                        ; This requests a 512-byte block of data that shows capabilities, CHS (not used), LBA Count, etc.
  1432                        ; The format is similar to Read LBA, except no LBA parameter is required. It effectively works as
  1433                        ; a Read Block operation and the data transferred is handled by the ISR for a Read Block.
  1434                        ; NOTE: The Identify Command is coded to load into the LBA_BUFFER (default address $0600).
  1435                        ;
  1436 00:FD04: A9 00                        LDA     #<LBA_BUFFER    ;Set Address low byte (2)
  1437 00:FD06: A0 06                        LDY     #>LBA_BUFFER    ;Set Address high byte (2)
  1438 00:FD08: A2 01                        LDX     #$01            ;Set Block count to 1 (2)
  1439 00:FD0A: 20 C7 F8                     JSR     IDE_SET_ADDRESS ;Set Xfer address and block count (6)
  1440                        IDENT_WAIT
  1441 00:FD0D: AD 36 FE                     LDA     IDE_ALT_STATUS  ;Get IDE Alternate Status register (4)
  1442 00:FD10: 30 FB                        BMI     IDENT_WAIT      ;Loop until BUSY bit is clear (2/3)
  1443                        
  1444                        
  1445 00:FD12: 20 EE F8                     JSR     IDE_SET_PARMS2  ;Setup required parameters (no LBA parameter) (6)
  1446                        ;
  1447 00:FD15: A9 EC                        LDA     #$EC            ;Get Identify Command (2)
  1448 00:FD17: 20 61 F8                     JSR     IDENT_READ      ;Use READ_LBA routine to finish (6)
  1449                        ;
  1450                        ; Identify data loaded in buffer. Now extract LBA count and store to Soft Config Data for usage
  1451                        ; by access routines (Read/Write). Four bytes are used and the format from the Identify
  1452                        ; Command are Low-order Word / High-order Word, where each word is in Big Endian. We will store
  1453                        ; the LBA count as Little Endian, Low-order Word / High-order Word.
  1454                        ; The offset from the buffer are Words 60-61 (decimal).
  1455                        ;
  1456                        ; A table is used to index the offset of bytes to move into consecutive soft data.
  1457                        ;
  1458 00:FD1A: A2 04                        LDX     #$04            ;Set count for 4 bytes (2)
  Sat Apr  4 2026 16:30                                                                                                    Page 31


  1459 00:FD1C: BC CB FF     LBA_SIZE        LDY     LBA_OFFSET-1,X  ;Get Offset to LBA count (4)
  1460 00:FD1F: B1 F2                        LDA     (LBA_ADDR_LOW),Y        ;Load LBA Data (5)
  1461 00:FD21: 9D 3B 02                     STA     LOAD_IDE-1,X    ;Store to Soft Config Data (5)
  1462 00:FD24: CA                           DEX                     ;Decrement count (2)
  1463 00:FD25: D0 F5                        BNE     LBA_SIZE        ;Loop back until done (2/3)
  1464 00:FD27: A9 02        SET_CACHE_WR    LDA     #$02            ;Command for set write cache (2)
  1465                        ;
  1466                        ; Enable/Disable Write Cache for Microdrive (single call)
