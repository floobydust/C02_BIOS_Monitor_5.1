  1274                        ;
  1275                        ;Core routines that are used to detect and configure additional I/O devices.
  1276                        ; The I/O devices supported by the 5.x Release of C02BIOS contains two I/O devices:
  1277                        ; - A Maxim DS1318 Realtime Clock - new device!
  1278                        ; - An IDE Device, i.e., IBM/Hitachi MicroDrive
  1279                        ;
  1280                        ;The first routine detects the DS1318 RTC, followed by the routine to detect the IDE device.
  1281                        ;
  1282                        ;**************************************************************************************************
  1283                        ;
  1284                        ;This routine detects the DS1318 RTC.
  1285                        ;
  1286                        ; According to the datasheet, the TE and ENOSC bits in register offset 0Ah will be set to "1"
  1287                        ; for normal update operation and the CCFG1 and CCFG0 bits will be "0" for normal operation.
  1288                        ;
  1289                        ; Note: With the W65C02 CPU, when an empty address is read by the CPU, the data that comes back
  1290                        ; will be a phantom of the upper byte of the address, or FEh for our hardware.
  1291                        ; This technique is used to detect both the DS1318 and the IDE device.
  1292                        ; If the TE and ENOSC are "1" and the CCFG1 and CCFG0 bits are "0", then the RTC is present and
  1293                        ; functioning. Only the upper 4 bits are needed to sense this, so we mask off the lower 4 bits
  1294                        ; and compare to "%11000000" to confirm the RTC.
  1295                        ;
  1296                        DETECT_RTC
  1297 00:FC83: AD 2A FE                     LDA     RTC_CONTROL_A   ;Get RTC Control Reg A (3)
  1298 00:FC86: 29 F0                        AND     #%11110000      ;Mask off bits for TE, ENOSC, CCFG1/0 (2)
  1299 00:FC88: C9 00                        CMP     #$11000000      ;Bits 7/6 should be on, 5/4 should be off (2)
  1300 00:FC8A: F0 01                        BEQ     FOUND_RTC       ;If bits are off, RTC is present (2/3)
  1301 00:FC8C: 60                           RTS                     ;Else Return, RTC not found (6)
  1302                        ;
  1303                        FOUND_RTC
  1304 00:FC8D: C7 FF                        SMB4    MATCH           ;Set Match Bit 4 for RTC present (5)
  1305 00:FC8F: A2 00                        LDX     #$00            ;Zero Index for RTC message (2)
  1306                        RTC_MSG_LP
  1307 00:FC91: BD B4 FF                     LDA     RTC_MSG,X       ;Get BIOS init msg (4)
  1308 00:FC94: F0 09                        BEQ     INIT_RTC_NC     ;If zero, msg done, go Init RTC (2/3)
  1309 00:FC96: 20 1C F8                     JSR     CHROUT          ;Send to console (6)
  1310 00:FC99: E8                           INX                     ;Increment Index
  1311 00:FC9A: 80 F5                        BRA     RTC_MSG_LP      ;Loop back until done (3)
  1312                        ;
  1313                        ;This routine reads the Binary data registers from the DS1318 RTC. Note that the DS1318 does not
  1314                        ; keep time and date variables, but a 32-bit binary number held in 4 registers. The 32-bit value
  1315                        ; is set by a separate program that considers "0000h" as Epoch time. As a result, if no RTC is
  1316                        ; present, the BIOS 32-bit RTC count starts at "0000h".
  1317                        ;
  1318                        INIT_RTC
  1319 00:FC9C: 4F FF 21                     BBR4    MATCH,NO_RTC    ;Check for RTC present, else exit (5/6,7)
  1320                        ;
  1321                        INIT_RTC_NC
  1322 00:FC9F: A2 64                        LDX     #DF_TICKS       ;Get BIOS default Tick count (2)
  1323 00:FCA1: 86 E6                        STX     TICKS           ;Reset the Tick count (3)
  1324                        ;
  1325                        RTC_UIP_LP
  1326 00:FCA3: AD 2C FE                     LDA     RTC_STATUS      ;Get RTC Status register (3)
  1327 00:FCA6: 29 40                        AND     #%01000000      ;Mask UIP bit (2)
  1328 00:FCA8: D0 F9                        BNE     RTC_UIP_LP      :Loop back util update is finished (2/3)
  1329                        ;
  1330 00:FCAA: A2 00                        LDX     #$00            ;Set X reg to zero for data xfer (2)
  1331 00:FCAC: A9 80                        LDA     #%10000000      ;Get TE Bit mask (2)
  1332 00:FCAE: 1C 2A FE                     TRB     RTC_CONTROL_A   ;Turn off TE Bit to disable update (6)
  Sat Apr  4 2026 16:30                                                                                                    Page 29


  1333                        ;
  1334                        RTC_LOAD_LOOP
  1335 00:FCB1: BD 22 FE                     LDA     RTC_SECONDS_0,X ;Get data from RTC (4)
  1336 00:FCB4: 95 E7                        STA     SECS_0,X        ;Store into RAM (4)
