    90                        ;**************************************************************************************************
    91                        ;                                    START OF BIOS CODE                                           *
    92                        ;**************************************************************************************************
    93                        ;C02BIOS version used here is 5.1 (new release with IDE bootable support)
    94                        ;
    95                        ; Contains the base BIOS routines in top 2KB of Flash ROM
    96                        ; - $F800 - $FDFF Core BIOS routines (1536 bytes)
    97                        ; - $FE00 - $FE3F reserved for hardware devices (64 bytes)
    98                        ; - $FE40 - $FEFF used for Vector and Hardware configuration and text data (192 bytes)
    99                        ; - $FF00 - $FFFF JMP table, startup, NMI/BRK/IRQ pre-post routines, init, BIOS msg (256 bytes)
   100                        ;
   101                        ; UPDATES:
   102                        ; NOTE: Version 5.x BIOS changes include:
   103                        ; - Vector and Config Data moved to Page $02
   104                        ; - Console I/O buffer moved to Page $03
   105                        ; - Second Serial port buffer moved to Page $04
   106                        ; - Page $05 reserved for future expansion/changes
   107                        ; - Disk LBA buffer is at Pages $06 - $07
   108                        ;
   109                        ; - Update to Version 5.1
   110                        ; - Changes to the IDE BIOS to perform a Software Reset for the Reset_IDE call.
   111                        ; - Changes to the Cold Start to provide a timeout to either Boot from the IDE device or jump to
   112                        ; - the Monitor Cold Start vector.
   113                        ;**************************************************************************************************
   114                        ; The following 32 functions are provided by BIOS via the JMP Table
   115                        ;
   116                        ; $FF00 IDE_RESET       ;Reset IDE Controller (Recalibrate Command)
   117                        ; $FF03 IDE_GET_STAT    ;Get Status and Error code
   118                        ; $FF06 IDE_IDENTIFY    ;Load IDE Identity Data to LBA Buffer
   119                        ; $FF09 IDE_READ_LBA    ;Read LBA into memory
   120                        ; $FF0C IDE_WRITE_LBA   ;Write LBA from memory
   121                        ; $FF0F IDE_SET_LBA     ;Set LBA number (24-bit support only)
   122                        ; $FF12 IDE_SET_ADDR    ;Set LBA transfer address (16-bit plus block count)
   123                        ; $FF15 IDE_EN_CACHE    ;Enable/Disable IDE Write Cache
   124                        ;
   125                        ; $FF18 CHR_STAT        ;Check Console Status
   126                        ; $FF1B CHRIN_NW        ;Data input from console (no waiting, clear carry if none)
   127                        ; $FF1E CHRIN           ;Data input from console
   128                        ; $FF21 CHROUT          ;Data output to console
   129                        ;
   130                        ; $FF24 CHRIN2          ;Data input from aux port
   131                        ; $FF27 CHROUT2         ;Data output to aux port
   132                        ;
   133                        ; $FF2A CNT_INIT        ;Reset Benchmark timing counters
   134                        ; $FF2D CNT_STRT        ;Start 10ms Benchmark timing counter
   135                        ; $FF30 CNT_STOP        ;Stop 10ms Benchmark timing counter
   136                        ; $FF33 CNT_DISP        ;Display Benchmark counter timing
   137                        ;
   138                        ; $FF36 SET_DLY         ;Set delay value for milliseconds and 16-bit counter
   139                        ; $FF39 EXE_MSDLY       ;Execute millisecond delay 1-256 * 10 milliseconds
   140                        ; $FF3C EXE_LGDLY       ;Execute long delay; millisecond delay * 16-bit count
   141                        ;
   142                        ; $FF3F PROMPTR         ;Print string to console
  Sat Apr  4 2026 16:30                                                                                                    Page 10


   143                        ;
   144                        ; $FF42 RTC_INIT        ;Initialize software RTC from DS1318 hardware RTC
   145                        ;
   146                        ; $FF45 PRSTAT          ;Display CPU registers to console
   147                        ;
   148                        ; $FF48 Reserved        ;Reserved for future expansion
   149                        ;
   150                        ; $FF4B INIT_VEC        ;Initialize soft vectors at $0200 from ROM
   151                        ; $FF4E INIT_CFG        ;Initialize soft config data at $0220 from ROM
   152                        ;
   153                        ; $FF51 INIT_28L92      ;Initialize SC28L92 - Port A as console at 115.2K, 8-N-1 RTS/CTS
   154                        ; $FF54 RESET_28L92     ;Reset SC28L92 - called before INIT_28L92
   155                        ;
   156                        ; $FF57 PANIC           ;Execute PANIC routine (disables IDE controller)
   157                        ; $FF5A BOOT_IDE        ;Boot IDE device - load LBA 0 to $0800 and jump to it
   158                        ;
   159                        ; $FF5D COLDSTRT        ;System cold start - RESET vector for W65C02S
   160                        ;**************************************************************************************************
   161                        ;                    Data In and Out routines for Console I/O buffer                              *
   162                        ;**************************************************************************************************
   163                        ;Data Input Port A routine:
   164                        ;
   165                        ; CHR_STAT checks to see if the input buffer has any characters and returns with the buffer count
   166                        ; in the A Reg. Any value from $00 - $7F is valid.
   167                        ;
   168                        ; CHRIN_NW uses CHRIN, returns if data is not available from the buffer with carry flag clear,
   169                        ; - else returns with data in A reg and carry flag set.
   170                        ;
   171                        ; CHRIN waits for data to be in the receive buffer, then returns with data in A reg.
   172                        ; Receive is IRQ driven/buffered with a size of 128 bytes.
   173                        ;
   174 00:F800: A5 D9        CHR_STAT        LDA     ICNT_A          ;Get Buffer Count (4)
   175 00:F802: 60                           RTS                     ;Return to caller (6)
   176                        ;
   177 00:F803: 18           CHRIN_NW        CLC                     ;Clear Carry flag for no data (2)
   178 00:F804: A5 D9                        LDA     ICNT_A          ;Get buffer count (4)
   179 00:F806: D0 05                        BNE     GET_CH          ;Branch if buffer is not empty (2/3)
   180 00:F808: 60                           RTS                     ;Or return to caller (6)
   181                        ;
   182 00:F809: A5 D9        CHRIN           LDA     ICNT_A          ;Get data count (3)
   183 00:F80B: F0 FC                        BEQ     CHRIN           ;If zero (no data, loop back) (2/3)
   184                        ;
   185 00:F80D: 5A           GET_CH          PHY                     ;Save Y Reg (3)
   186 00:F80E: A4 DA                        LDY     IHEAD_A         ;Get the buffer head pointer (3)
   187 00:F810: B9 00 03                     LDA     IBUF_A,Y        ;Get the data from the buffer (4)
   188 00:F813: E6 DA                        INC     IHEAD_A         ;Increment head pointer (5)
   189 00:F815: 77 DA                        RMB7    IHEAD_A         ;Strip off bit 7, 128 bytes only (5)
   190 00:F817: C6 D9                        DEC     ICNT_A          ;Decrement the buffer count (5)
   191                        ;
   192 00:F819: 7A                           PLY                     ;Restore Y Reg (4)
   193 00:F81A: 38                           SEC                     ;Set Carry flag for data available (2)
   194 00:F81B: 60                           RTS                     ;Return to caller with data in A Reg (6)
   195                        ;
   196                        ;Data Output Port A routine:
   197                        ; CHROUT puts the data in the A Reg into the xmit buffer, data in A Reg is preserved on exit.
   198                        ; Transmit is IRQ driven/buffered with a size of 128 bytes.
   199                        ;
   200 00:F81C: 5A           CHROUT          PHY                     ;Save Y Reg (3)
   201 00:F81D: A4 DC        OUTCH           LDY     OCNT_A          ;Get data output count in buffer (3)
   202 00:F81F: 30 FC                        BMI     OUTCH           ;Check against limit, loop back if full (2/3)
   203                        ;
   204 00:F821: A4 DE                        LDY     OTAIL_A         ;Get the buffer tail pointer (3)
   205 00:F823: 99 80 03                     STA     OBUF_A,Y        ;Place data in the buffer (5)
  Sat Apr  4 2026 16:30                                                                                                    Page 11


   206 00:F826: E6 DE                        INC     OTAIL_A         ;Increment Tail pointer (5)
   207 00:F828: 77 DE                        RMB7    OTAIL_A         ;Strip off bit 7, 128 bytes only (5)
   208 00:F82A: E6 DC                        INC     OCNT_A          ;Increment data count (5)
   209                        ;
   210 00:F82C: A0 04                        LDY     #%00000100      ;Get mask for xmit on (2)
   211 00:F82E: 8C 02 FE                     STY     UART_COMMAND_A  ;Turn on xmit (4)
   212                        ;
   213 00:F831: 7A                           PLY                     ;Restore Y Reg (4)
   214 00:F832: 60                           RTS                     ;Return to caller (6)
   215                        ;
   216                        ;Data Input Port B routine:
   217                        ; CHRIN2 waits for data to be in the receive buffer, then returns with data in A reg.
   218                        ; Receive is IRQ driven/buffered with a size of 128 bytes.
   219                        ;
   220 00:F833: A5 DF        CHRIN2          LDA     ICNT_B          ;Get data count (3)
   221 00:F835: F0 FC                        BEQ     CHRIN2          ;If zero (no data, loop back) (2/3)
   222                        ;
   223 00:F837: 5A                           PHY                     ;Save Y Reg (3)
   224 00:F838: A4 DA                        LDY     IHEAD_A         ;Get the buffer head pointer (3)
   225 00:F83A: B9 00 04                     LDA     IBUF_B,Y        ;Get the data from the buffer (4)
   226 00:F83D: E6 E0                        INC     IHEAD_B         ;Increment head pointer (5)
   227 00:F83F: 77 E0                        RMB7    IHEAD_B         ;Strip off bit 7, 128 bytes only (5)
   228 00:F841: C6 DF                        DEC     ICNT_B          ;Decrement the buffer count (5)
   229                        ;
   230 00:F843: 7A                           PLY                     ;Restore Y Reg (4)
   231 00:F844: 60                           RTS                     ;Return to caller with data in A Reg (6)
   232                        ;
   233                        ;Data Output Port B routine:
   234                        ; CHROUT2 puts the data in the A Reg into the xmit buffer, data in A Reg is preserved on exit.
   235                        ; Transmit is IRQ driven/buffered with a size of 128 bytes.
   236                        ;
   237 00:F845: 5A           CHROUT2         PHY                     ;Save Y Reg (3)
   238 00:F846: A4 E2        OUTCH2          LDY     OCNT_B          ;Get data output count in buffer (3)
   239 00:F848: 30 FC                        BMI     OUTCH2          ;Check against limit, loop back if full (2/3)
   240                        ;
   241 00:F84A: A4 E4                        LDY     OTAIL_B         ;Get the buffer tail pointer (3)
   242 00:F84C: 99 80 04                     STA     OBUF_B,Y        ;Place data in the buffer (5)
   243 00:F84F: E6 E4                        INC     OTAIL_B         ;Increment Tail pointer (5)
   244 00:F851: 77 E4                        RMB7    OTAIL_B         ;Strip off bit 7, 128 bytes only (5)
   245 00:F853: E6 E2                        INC     OCNT_B          ;Increment data count (5)
   246                        ;
   247 00:F855: A0 04                        LDY     #%00000100      ;Get mask for xmit on (2)
   248 00:F857: 8C 0A FE                     STY     UART_COMMAND_B  ;Turn on xmit (4)
   249                        ;
   250 00:F85A: 7A                           PLY                     ;Restore Y Reg (4)
   251 00:F85B: 60                           RTS                     ;Return to caller (6)
   252                        ;
   253                        ;**************************************************************************************************
   254                        ;START of IDE Data Transfer Routines for Hitachi 3K8 MicroDrive
   255                        ; These routines requires loading the requested LBA into the appropriate registers and
   256                        ; issuing the READ or WRITE command. The LBA limit supported for the BIOS are bits 0-23,
   257                        ; so bits 24-27 are always set to 0. This provides access to IDE devices up to 8GB.
   258                        ;
   259                        ; Once the registers/parameters are setup, the Read or Write Block command is issued.
   260                        ; This results in an interrupt being generated. The ISR handles the transfer of LBA
   261                        ; data from the IDE Drive to memory. Write operations move data from memory to IDE Drive here,
   262                        ; but uses an interrupt to finalize the transfer.
   263                        ;
   264                        ; The registers used are the same for read/write. These are:
   265                        ;
   266                        ;       IDE_COMMAND = function requested (20h = READ LBA command - 30h = WRITE LBA command)
   267                        ;       IDE_DRV_HEAD = (Upper 4 bits) used as:
   268                        ;               bit 7 = 1 per Seagate documentation
  Sat Apr  4 2026 16:30                                                                                                    Page 12


   269                        ;               bit 6 = 1 for LBA mode
   270                        ;               bit 5 = 1 per Seagate documentation
   271                        ;               bit 4 = 0 for Drive 0
   272                        ;       IDE_DRV_HEAD = LBA Address bits 27-24 (lower 4 bits) - not used, always 0000
   273                        ;       IDE_CYL_HIGH = LBA Address bits 23-16
   274                        ;       IDE_CYL_LOW = LBA Address bits 15-8
   275                        ;       IDE_SCT_NUM = LBA Address bits 7-0
   276                        ;       IDE_SCT_CNT = number of blocks to read
   277                        ;**************************************************************************************************
   278                        ;
   279                        IDE_READ_LBA                            ;Read a Block of data from IDE device
   280                        ;
   281 00:F85C: 20 D5 F8                     JSR     IDE_SET_PARMS   ;Setup required parameters (6)
   282 00:F85F: A9 20                        LDA     #$20            ;Get Read LBA command (2)
   283                        IDENT_READ                              ;Identify Command jumps here to complete
   284 00:F861: B7 FF                        SMB3    MATCH           ;Set Read LBA bit (5)
   285 00:F863: 8D 3F FE                     STA     IDE_COMMAND     ;Send command to IDE Controller (4)
   286                        ;
   287                        LBA_RD_CMD
   288 00:F866: AD 36 FE                     LDA     IDE_ALT_STATUS  ;Get IDE Alternate Status register (4)
   289 00:F869: 30 FB                        BMI     LBA_RD_CMD      ;Loop until IDE controller not Busy (2/3)
   290                        ;
   291                        LBA_RD_WAIT
   292 00:F86B: AD 36 FE                     LDA     IDE_ALT_STATUS  ;Get IDE Alternate Status register (4)
   293 00:F86E: C9 50                        CMP     #$50            ;Compare for ready (2)
   294 00:F870: D0 04                        BNE     LBA_RD_ERR      ;If not, check for error condition (2/3)
   295                        LBA_RD_OK
   296 00:F872: BF FF FD                     BBS3    MATCH,LBA_RD_OK ;Wait for Read completed via ISR (5/6,7)
   297 00:F875: 60                           RTS                     ;Return to caller (status in A Reg) (6)
   298                        LBA_RD_ERR
   299 00:F876: 4A                           LSR     A               ;Shift error bit to carry (2)
   300 00:F877: 90 F2                        BCC     LBA_RD_WAIT     ;If clear, loop back and continue waiting (2/3)
   301                        ;
   302 00:F879: 37 FF                        RMB3    MATCH           ;Reset Read LBA bit (no ISR invoked) (5)
   303                        IDE_RWV_FIN
   304 00:F87B: AD 36 FE                     LDA     IDE_ALT_STATUS  ;Get IDE Alternate Status register (4)
   305 00:F87E: 85 FB                        STA     IDE_STATUS_RAM  ;Update RAM Status Register (3)
   306 00:F880: 60                           RTS                     ;Return to caller (6)
   307                        ;**************************************************************************************************
   308                        ;
   309                        IDE_WRITE_LBA                           ;Write a block of data to LBA
   310                        ;
   311 00:F881: 20 D5 F8                     JSR     IDE_SET_PARMS   ;Setup required parameters (6)
   312                        ;
   313 00:F884: A7 FF                        SMB2    MATCH           ;Set Write LBA bit (5)
   314 00:F886: A9 30                        LDA     #$30            ;Get Write LBA command (2)
   315 00:F888: 8D 3F FE                     STA     IDE_COMMAND     ;Send command to IDE Controller (4)
   316                        LBA_WR_CMD
   317 00:F88B: AD 36 FE                     LDA     IDE_ALT_STATUS  ;Get IDE Alternate Status register (4)
   318 00:F88E: 30 FB                        BMI     LBA_WR_CMD      ;Loop until IDE controller not Busy (2/3)
   319 00:F890: 4A                           LSR     A               ;Shift Error bit into Carry flag (2)
   320 00:F891: B0 30                        BCS     IDE_WRITE_ERR   ;If Carry set, IDE error (2/3)
   321                        ;
   322                        ; Write Block routine integrated into IDE_WRITE_LBA
   323                        ; - High byte needs to be loaded into the latch before the
   324                        ;   low byte is loaded into the Data Register!
   325                        ;
