  1468                        ;
  1469                        IDE_SET_CACHE
  1470 00:FD29: 8D 39 FE                     STA     IDE_FEATURE     ;Send to IDE controller (4)
  1471 00:FD2C: A9 E0                        LDA     #%11100000      ;Get Drive 0, LBA. mode, etc. (2)
  1472 00:FD2E: 8D 3E FE                     STA     IDE_DRV_HEAD    ;Send to IDE controller (4)
  1473 00:FD31: A9 EF                        LDA     #$EF            ;Get Set Features Command (2)
  1474 00:FD33: 8D 3F FE                     STA     IDE_COMMAND     ;Send Command to set feature (4)
  1475 00:FD36: 20 02 F9                     JSR     TST_IDE_RDY     ;Test for Drive ready (6)
  1476 00:FD39: AD 3F FE                     LDA     IDE_STATUS      ;Get Status (4)
  1477 00:FD3C: AE 39 FE                     LDX     IDE_ERROR       ;Get Error (if any) (4)
  1478 00:FD3F: 60                           RTS                     ;Return to Caller (6)
  1479                        ;
  1480                        ; Reset IDE Controller and run Diagnostics
  1481                        ; The RECAL routine disables the IRQ function, so the routine to enable the IRQ
  1482                        ; is called, then drops into the get status routine before returning.
  1483                        ;
  1484                        ; Note: If an error occurs, the drive must be Reset to clear the error code!
  1485                        ; There are only 3 ways to clear a driver error:
  1486                        ; - Send a software reset command
  1487                        ; - Toggle the hardware Reset line
  1488                        ; - Perform a PowerOff/PowerOn sequence
  1489                        ;
  1490                        ; A software reset of the IDE controller is done by setting the SRST bit in the
  1491                        ; command register to a "1" for at least 5 microseconds, then clearing the SRST bit
  1492                        ; back to a "0".
  1493                        ;
  1494                        ; The IDE_RESET routine here will first perform a Software Reset to the controller,
  1495                        ; then issue a Drive Recalibrate command reset the Write Cache to on, then exit.
  1496                        ;
  1497                        IDE_RESET                               ;Do a Reset of IDE device
  1498 00:FD40: A9 04                        LDA     #%00000100      ;Get mask to set software reset (SRST bit) (2)
  1499 00:FD42: 8D 36 FE                     STA     IDE_DEV_CTRL    ;Send to control register (4)
  1500                        ;
  1501 00:FD45: A9 01                        LDA     #1              ;Setup timer for 10ms on MS delay (2)
  1502 00:FD47: A2 00                        LDX     #0              ;Setup timer for 0 multiplier (2)
  1503 00:FD49: A0 00                        LDY     #0              ; (2)
  1504 00:FD4B: 20 82 F9                     JSR     SET_DLY         ;Call routine to set values (6)
  1505 00:FD4E: 20 89 F9                     JSR     EXE_MSDLY       ;Execute 10ms delay (6)
  1506                        ;
  1507 00:FD51: A9 00                        LDA#%0000000            ;Get mask to reset software reset (SRST bit) (2)
  1508 00:FD53: 8D 36 FE                     STA     IDE_DEV_CTRL    ;Send to control register (4)
  1509                        ;
  1510 00:FD56: 20 71 FD                     JSR     IDE_RECAL       ;Call IDE_RESET (set LBA mode) (6)
  1511 00:FD59: 20 27 FD                     JSR     SET_CACHE_WR    ;Enable Write Cache (6)
  1512 00:FD5C: A9 08                        LDA     #%00001000      ;Get Mask to enable IRQ (2)
  1513 00:FD5E: 8D 36 FE                     STA     IDE_DEV_CTRL    ;Send to control register (4)
  1514                        ;
  1515                        ; Drop into Get Status routine after Diagnostics are run
  1516                        ;
  1517                        IDE_GET_STATUS                          ;Get Status/Error registers from the IDE controller
  1518                        ;
  1519                        ; This routine gets the current status of the IDE Controller and can be issued at any time.
  1520                        ; It does not rely on any interrupt capability as it's a simple read of the Status and the
  1521                        ; Error registers from the IDE Controller.
  Sat Apr  4 2026 16:30                                                                                                    Page 32


  1522                        ;
  1523                        ; Note: This routine should be called whenever an Error has occurred. It returns the contents of
  1524                        ; the Error Register in the X Register and the contents of the Status Register in the A Register.
  1525                        ;
  1526                        ; Details for the Registers are:
  1527                        ;
  1528                        ; Error Register:
  1529                        ;Bit 7 - CRC Error or Bad Block error
  1530                        ;Bit 6 - Uncorrectable Data Error
  1531                        ;Bit 5 - 0 (not used) MC (used for Removable-Media drives)
  1532                        ;Bit 4 - ID Not Found
  1533                        ;Bit 3 - 0 (not used) MCR (used for Removable-Media drives)
  1534                        ;Bit 2 - Aborted Command error
  1535                        ;Bit 1 - Track Zero not found error
  1536                        ;Bit 0 - Data Address Mark Not Found
  1537                        ;
  1538                        ; Status Register:
  1539                        ;Bit 7 - Busy - IDE Controller is Busy (all other bits invalid)
  1540                        ;Bit 6 - Drive Ready (IDE Controller Ready to accept Commands)
  1541                        ;Bit 5 - Drive Write Fault - Write Fault error has occurred
  1542                        ;Bit 4 - Drive Seek Complete - is active when the drive is not seeking
  1543                        ;Bit 3 - Data Request - bit set when the IDE Controller has Data to transfer (R/W)
  1544                        ;Bit 2 - Correctable Data - bit set when bad data was found and corrected (ECC)
  1545                        ;Bit 1 - Index - bit toggled from 0 to 1 once per disk revolution
  1546                        ;Bit 0 - Error - bit set when previous command ended with some sort of error
  1547                        ;
  1548 00:FD61: AD 36 FE                     LDA     IDE_ALT_STATUS  ;Get IDE Alternate Status register (4)
  1549 00:FD64: 30 FB                        BMI     IDE_GET_STATUS  ;Loop until BUSY bit is clear (2/3)
  1550                        ;
  1551 00:FD66: AD 3F FE                     LDA     IDE_STATUS      ;Get IDE Status Register (4)
  1552 00:FD69: AE 39 FE                     LDX     IDE_ERROR       ;Get IDE Error Register (4)
  1553 00:FD6C: 60                           RTS                     ;Return to Caller (6)
  1554                        ;
  1555                        IDE_DIAG                                ;Run internal Diagnostics on the IDE controller
  1556                        ;
  1557                        ;This is a basic self test for the IDE controller. This runs some internal tests for the
  1558                        ; IDE controller and returns with drive ready bits active ($50) and the error register as
  1559                        ; $01 if successful. For Diagnostics, the Error Register contains unique codes as follows:
  1560                        ;
  1561                        ;01h - No error Detected
  1562                        ;02h - Formatter device error
  1563                        ;03h - Sector Buffer error
  1564                        ;04h - ECC Circuitry error
  1565                        ;05h - Controller Microprocessor error
  1566                        ;8xH - Device 1 failed (not valid with a single drive system)
  1567                        ;
  1568                        ; Note: 80h ORed in for the Slave (second) Drive, lower bit definitions are the same!
  1569                        ;
  1570 00:FD6D: A9 90                        LDA     #$90            ;Get Diagnostic Command (2)
  1571 00:FD6F: 80 02                        BRA     IDE_SEND_CMD    ;Branch and send Command to IDE (3)
  1572                        ;
  1573                        IDE_RECAL                               ;Recalibrate Command
  1574                        ;
  1575                        ;This is the Recalibrate Command ($1x). Upon issue the IDE controller will move the heads to
  1576                        ; Cylinder 0 and read Head 0, Sector 1. If unsuccessful, an error will be posted.
  1577                        ;
  1578 00:FD71: A9 10                        LDA     #$10            ;Get Recalibrate Command (2)
  1579                        ;
  1580                        IDE_SEND_CMD                            ;Send a Command to the IDE controller
  1581                        ;
  1582                        ;Accepts a Command code via the A reg and sets up the necessary IDE Controller
  1583                        ; registers to accept it. It also tests to ensure the controller is ready
  1584                        ; to accept the command and get the Status and Error registers on return.
  Sat Apr  4 2026 16:30                                                                                                    Page 33


  1585                        ;
  1586 00:FD73: AA                           TAX                     ;Save Command to X Reg (2)
  1587 00:FD74: 20 02 F9                     JSR     TST_IDE_RDY     ;Wait for IDE to be ready (6)
  1588 00:FD77: A9 0A                        LDA     #%00001010      ;Get Mask to disable IRQ (2)
  1589 00:FD79: 8D 36 FE                     STA     IDE_DEV_CTRL    ;Send to control register (4)
  1590 00:FD7C: A9 E0                        LDA     #%11100000      ;Get Select Mask (LBA Mode, Drive 0) (2)
  1591 00:FD7E: 8D 3E FE                     STA     IDE_DRV_HEAD    ;Select Drive 0 (4)
  1592                        ;
  1593 00:FD81: 8E 3F FE                     STX     IDE_COMMAND     ;Send command to IDE (4)
  1594                        SEND_CMD_LP
  1595 00:FD84: AD 36 FE                     LDA     IDE_ALT_STATUS  ;Get IDE Alternate Status register (4)
  1596 00:FD87: 30 FB                        BMI     SEND_CMD_LP     ;Loop until BUSY bit is clear (2/3)
  1597                        ;
  1598 00:FD89: AD 3F FE                     LDA     IDE_STATUS      ;Get IDE Status Register (4)
  1599 00:FD8C: AE 39 FE                     LDX     IDE_ERROR       ;Get IDE Error Register (4)
  1600 00:FD8F: 60                           RTS                     ;Return to caller (6)
  1601                        ;
  1602                        ; Enable Interrupts on the IDE Controller. This needs to be executed during initial setup
  1603                        ; and anytime the Reset/Diag BIOS function is called.
  1604                        ;
  1605                        IDE_EN_IRQ                              ;Enable IDE Controller interrupt
  1606 00:FD90: 20 02 F9                     JSR     TST_IDE_RDY     ;Wait for IDE to be ready (6)
  1607 00:FD93: A9 08                        LDA     #%00001000      ;Get Mask to enable IRQ (2)
  1608 00:FD95: 8D 36 FE                     STA     IDE_DEV_CTRL    ;Send to control register (4)
  1609 00:FD98: 60                           RTS                     ;Return to caller (6)
  1610                        ;
  1611                        ;**************************************************************************************************
  1612                        ;
  1613                        ;Interrupt 1 - This is the ISR which is responsible for servicing the IDE controller.
  1614                        ; The RTC does not require any ISR capabilities as no Alarm functions are being used in the BIOS.
  1615                        ; There are extra inserts which can be used if needed at a later date.
  1616                        ; The only functions that might make sense would be to add the Alarm function at a future date.
  1617                        ;
  1618                        ;The ISR for the IDE controller will handle the data transfer for LBA read/write functions
  1619                        ; and handle any error conditions. By design, the 16-bit Data Transfer feature is used for:
  1620                        ; Reading and Writing of all LBA block data and the IDE Identification data.
  1621                        ;
  1622                        ;The BIOS is using the Alternate Status register to determine if DRQ (Data Request) is active.
  1623                        ; This works as a handshake for 16-bit data transfers without issue. Note that the normal Status
  1624                        ; register resets the interrupt when read, so this is only done once in the ISR per loop.
  1625                        ;
  1626                        ;Update: This ISR has been moved to the front of the ISR chain, i.e., this ISR routine gets
  1627                        ; serviced first, then jumps to the next ISR, which services the DUART. This makes a noticeable
  1628                        ; improvement in data transfer from the IDE controller. Note that overhead for this routine will
  1629                        ; add 33 clock cycles if it just exits (IDE controller did not generate an interrupt).
  1630                        ;
  1631                        ;To check if an interrupt has been generated by the IDE controller, the Alternate Status register
  1632                        ; will be read. This contains the same information as the standard Status register but will NOT
  1633                        ; reset the interrupt on the IDE controller. By reading the Alternate Status register first, we
  1634                        ; can determine what the status of the IDE controller is and take action if required.
  1635                        ; Note that not all bit settings imply an interrupt was generated. Specifically, looking at the
  1636                        ; bit definitions below, Bits 6 and 4 are set when the IDE is ready, hence a normal condition
  1637                        ; where nothing requires any attention. Also, a Busy condition can imply the IDE controller is
  1638                        ; working on a command but may not have generated an interrupt yet. If The Busy bit (7) is set,
  1639                        ; then all other bits are invalid per Seagate documentation, so we test for that first.
  1640                        ;
  1641                        ;One annoying feature of IDE is "when" interrupts are generated. For any Read operation, once
  1642                        ; the command has been accepted, data is placed into the IDE buffer, followed by generating
  1643                        ; an interrupt to the system. Once this is done, the system will read the data. By accessing the
  1644                        ; Status register, the interrupt will be reset. This is normal operation. For a write operation,
  1645                        ; The command is sent, then DRQ goes active, which requires the data be sent to the IDE Device.
  1646                        ; Once the data is written, an interrupt is generated after it's writing is completed.
  1647                        ; As a result, there's little value of having an ISR for servicing the write function.
  Sat Apr  4 2026 16:30                                                                                                    Page 34


  1648                        ; As interrupts are enabled for the IDE Controller, all generated interrupts must be handled.
  1649                        ;
  1650                        ; Status Register bits as defined as follows:
  1651                        ;       - Bit 7 = Busy (a Command has been accepted)
  1652                        ;       - Bit 6 = Ready (IDE controller is ready to accept a command)
  1653                        ;       - Bit 5 = Write Fault (A write command failed against the media)
  1654                        ;       - Bit 4 = DSC (is set when a Seek is completed)
  1655                        ;       - Bit 3 = Data Request (set when there is data to transfer, read or write)
  1656                        ;       - Bit 2 = Correction (set when a recoverable data error was corrected)
  1657                        ;       - Bit 1 = 0 (not used)
  1658                        ;       - Bit 0 = Error (set when the previous command had an unrecoverable error)
  1659                        ;
  1660                        ;       NOTE: 25 clock cycles to here if DUART ISR is second!
  1661                        ;
  1662                        INTERUPT1                               ;Interrupt 1 (IDE)
  1663 00:FD99: AD 36 FE                     LDA     IDE_ALT_STATUS  ;Get Alternate Status Register (4)
  1664 00:FD9C: 30 39                        BMI     REGEXT01        ;If Busy bit active, just exit (2/3)
  1665                        ;
  1666                        ; - Check for Data Request (DRQ), as the Read LBA operation is the main function
  1667                        ;   of the ISR, which will handle the data transfer from the IDE controller to store the
  1668                        ;   data into memory. This ISR will handle single and multiple block transfers.
  1669                        ;
  1670 00:FD9E: AD 3F FE                     LDA     IDE_STATUS      ;Get Status (resets IRQ) (4)
  1671 00:FDA1: 29 08                        AND     #%00001000      ;Check for DRQ (2)
  1672 00:FDA3: D0 05                        BNE     IDE_READ_BLK    ;Branch if active (2/3)
  1673                        ;
  1674                        ;If no DRQ is sensed, the other possibility is a LBA Write has occurred and an IRQ
  1675                        ; was generated after the transfer. So we check for this and branch accordingly.
  1676                        ;
  1677 00:FDA5: AF FF 32                     BBS2    MATCH,IDE_WRIT_BLK      ;If Bit 2 set, Write operation (5/6,7)
  1678 00:FDA8: 80 2D                        BRA     REGEXT01        ;Exit ISR handler (3)
  1679                        ;
  1680                        IDE_READ_BLK                            ;IDE Read a Block of data
  1681                        ;
  1682                        ;Note: Arrival here means that the DRQ bit in the status register is active.
  1683                        ; This implies that:
  1684                        ;  1- A LBA Block Read is in progress. If so, the data transfer will be handled below.
  1685                        ;     This also handles multiple LBA Reads and manages the pointers and such. It also
  1686                        ;     clears the LBA Read bit in the MATCH Flag when completed.
  1687                        ;
  1688                        ;  2- A LBA Block Write with multilpe blocks is in progress. If so, the actual data
  1689                        ;     transfer is handled via the IDE WRITE Block routine. An interrupt is generated
  1690                        ;     at the end of each LBA transfer, so that is monitored here and the LBA Write bit
  1691                        ;     in the MATCH Flag is cleared when there are no more blocks to transfer.
  1692                        ;
  1693                        ;Also realize that this ISR will be executed every time the DUART generates an interrupt.
  1694                        ; This will happen every 10ms for the Jiffy-Clock timer and for character transmit and receive.
  1695                        ;
  1696 00:FDAA: 3F FF 2A                     BBR3    MATCH,REGEXT01  ;If Bit 3 clear, IDE Write (5/6,7)
  1697                        ;
  1698 00:FDAD: AD 36 FE     LBA_XFER        LDA     IDE_ALT_STATUS  ;Get Status (4)
  1699 00:FDB0: 29 08                        AND     #%00001000      ;Check for DRQ (2)
  1700 00:FDB2: F0 18                        BEQ     IDE_RD_DONE     ;If not active, done, exit (2/3)
  1701                        ;
  1702                        IDE_RD_RBLK
  1703 00:FDB4: AD 38 FE                     LDA     IDE_DATA        ;Read low byte (high byte in latch) (4)
  1704 00:FDB7: 92 F8                        STA     (BIOS_XFERL)    ;Store low byte (5)
