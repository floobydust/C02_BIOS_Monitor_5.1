   882                        IDE_ERROR_HANDLER
   883                        ; This routine gets the error code anytime a command returns with the error
   884                        ; bit on in the status register. It uses the BIOS routine to get the error register
   885                        ; and returns with the error code in the X register.
   886                        ;
   887                        ; the error code is matched to the list of possible codes per the Hitachi
   888                        ; MicroDrive documentation, then the matching error message is sent to the console.
   889                        ; After this, the IDE controller is reset and the User is prompted for the next
   890                        ; action to be taken.
   891                        ;
   892 00:0CF8: A9 26                        LDA     #<IDE_CONTROLLER_ERROR  ;Get Base IDE error msg
   893 00:0CFA: A0 1B                        LDY     #>IDE_CONTROLLER_ERROR
   894 00:0CFC: 20 3F FF                     JSR     B_PROMPTR               ;Send to console
   895                        ;
   896 00:0CFF: A5 DC        OC_LOOP5        LDA     OCNT_A                  ;Check output buffer count
   897 00:0D01: D0 FC                        BNE     OC_LOOP5                ;Loop back until buffer sent
   898                        ;
   899 00:0D03: 20 03 FF                     JSR     B_IDE_GET_STAT          ;Get Status from BIOS
   900 00:0D06: 8A                           TXA                             ;Xfer error code to A reg
   901                        ;
   902 00:0D07: A2 05                        LDX     #IDE_ERROR_ADDRESS-IDE_ERROR_CODES-1    ;Get error list count
   903 00:0D09: DD 60 1D     ERROR_LP        CMP     IDE_ERROR_CODES,X       ;Compare to command list
   904 00:0D0C: D0 0B                        BNE     ERROR_DEC               ;Check for next error and loop
   905                        ;
   906                        ; X Reg now contains error index
   907                        ;
   908 00:0D0E: 8A                           TXA                             ;Xfer Error code index to A reg
   909 00:0D0F: 0A                           ASL     A                       ;Multiply error index value by 2
   910 00:0D10: AA                           TAX                             ;Xfer Error offset address to message table
   911                        ;
   912 00:0D11: BD 66 1D                     LDA     IDE_ERROR_ADDRESS,X     ;Get message address
   913 00:0D14: BC 67 1D                     LDY     IDE_ERROR_ADDRESS+1,X
   914 00:0D17: 80 07                        BRA     ERROR_MSG               ;Branch below to output message and continue
   915                        ;
   916 00:0D19: CA           ERROR_DEC       DEX                             ;Decrement index count
   917 00:0D1A: 10 ED                        BPL     ERROR_LP                ;If more to check, loop back
   918                        ;
   919                        ; No more error codes, so it must be something unknown. So print the unknown message
   920                        ; to the console and return to the User prompt.
   921                        ;
   922 00:0D1C: A9 F6                        LDA     #<IDE_ERROR_06          ;Get Error message address
   923 00:0D1E: A0 1D                        LDY     #>IDE_ERROR_06
   924                        ERROR_MSG
   925 00:0D20: 20 3F FF                     JSR     B_PROMPTR               ;Send to console
   926                        ;
   927 00:0D23: A5 DC        OC_LOOP6        LDA     OCNT_A                  ;Check output buffer count
   928 00:0D25: D0 FC                        BNE     OC_LOOP6                ;Loop back until buffer sent
   929                        ;
   930 00:0D27: 20 00 FF                     JSR     B_IDE_RESET             ;Reset IDE Controller
   931 00:0D2A: 4C CE 0C                     JMP     USER_INPUT              ;Prompt User
   932                        ;
   933                        GET_PATTERN
   934                        ; Get Pattern: This prompts the User for a 2-byte Hexadecimal fill pattern.
   935                        ; - This will be used by FILL_PATTERN to load the BENCH_BUFFER.
   936 00:0D2D: A9 9F                        LDA     #<PATTERN_MSG           ;Get write pattern msg
   937 00:0D2F: A0 18                        LDY     #>PATTERN_MSG
   938 00:0D31: 20 3F FF                     JSR     B_PROMPTR               ;Send to console
   939                        ;
   940                        ; Monitor routine will get User input and return in A/Y regs
   941                        ; - Data also saved in INDEXH/INDEXL
   942 00:0D34: 20 9E 0F                     JSR     HEXIN4                  ;Use Monitor to get input
   943 00:0D37: 4C 8A 0F                     JMP     CROUT                   ;Send C/R to console and return
   944                        ;
  Fri Apr 24 2026  6:57                                                                                                    Page 24


   945                        FILL_PATTERN
   946                        ;
   947                        ; Fill Pattern: This fills the LBA buffer with a user specified data pattern.
   948                        ; - The buffer address is specified by BENCH_BUFFER (at the end of our code).
   949                        ; - For ease of coding, we default to a 16KB fill buffer.
   950                        ; - The 16KB buffer is used by the Read and Write Benchmark routines only.
   951                        ;
   952 00:0D3A: A9 00                        LDA     #<BENCH_BUFFER          ;Setup LBA Buffer
   953 00:0D3C: A0 1F                        LDY     #>BENCH_BUFFER          ; address
   954 00:0D3E: 85 AE                        STA     TGTL                    ;Setup Page Zero pointer lo
   955 00:0D40: 84 AF                        STY     TGTH                    ;Setup Page Zero pointer hi
   956                        ;
   957 00:0D42: A2 00                        LDX     #$00                    ;Set Index for count
   958 00:0D44: A0 40                        LDY     #$40                    ; of 32KB (16K of words)
   959                        FILL_P_LOOP
   960 00:0D46: A5 A9                        LDA     INDEXH                  ;Get High byte fill
   961 00:0D48: 92 AE                        STA     (TGTL)                  ;Save it
   962 00:0D4A: E6 AE                        INC     TGTL                    ;Increment pointer
   963 00:0D4C: D0 02                        BNE     SK_FILL_1               ;Skip if no rollover
   964 00:0D4E: E6 AF                        INC     TGTH                    ;Increment pointer
   965                        SK_FILL_1
   966 00:0D50: A5 A8                        LDA     INDEXL                  ;Get Low byte fill
   967 00:0D52: 92 AE                        STA     (TGTL)                  ;Save it
   968 00:0D54: E6 AE                        INC     TGTL                    ;Increment pointer
