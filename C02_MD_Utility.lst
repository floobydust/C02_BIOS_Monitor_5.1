  1009                        SYS_XFER
  1010                        ;
  1011                        ;System Transfer routine.
  1012                        ; This routine is used to write a section of memory to a defined set of contiguous blocks
  1013                        ; on the Microdrive. The purpose being to transfer the bootable image from RAM to the disc.
  1014                        ;
  1015                        ; The user is prompted for a few inputs as:
  1016                        ; - Starting LBA on the Microdrive
  1017                        ; - Starting memory address used as the source
  1018                        ; - Number of blocks to be transferred
  1019                        ;
  1020                        ; Once this is entered, the user is prompted to either continue or abort.
  1021                        ; if confirmed, the write executed and the blocks on the disc are overwritten with the
  1022                        ; contens of memory.
  1023                        ;
  1024 00:0D87: A9 5C                        LDA     #<SYS_INTRO_MSG         ;Get System Xfer Message
  1025 00:0D89: A0 1B                        LDY     #>SYS_INTRO_MSG         ;
  1026 00:0D8B: 20 3F FF                     JSR     B_PROMPTR               ;Send to Console
  1027                        ;
  1028 00:0D8E: A9 D4                        LDA     #<SYS_LBA_MSG           ;Get Starting LBA for xfer
  1029 00:0D90: A0 1B                        LDY     #>SYS_LBA_MSG           ;
  1030 00:0D92: 20 3F FF                     JSR     B_PROMPTR               ;Send to Console
  1031 00:0D95: 20 D8 0C                     JSR     GET_LBA_NUM             ;Get starting LBA from User
  1032                        ;
  1033                        ; Use C02 Monitor routine to get a 16-bit hex address returned in A/Y
  1034                        ; and stored in INDEXH/INDEXL
  1035                        ;
