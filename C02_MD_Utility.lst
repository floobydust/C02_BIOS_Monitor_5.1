   664                        IDE_BENCHMARK
   665                        ;
   666                        ; The Benchmark will read or write a 32MB contiguous block of data.
   667                        ;  The starting LBA is entered by the user.
   668                        ;
   669                        ; - The Benchmark timer in the C02 BIOS/Monitor is used to time the data transfer and shows
   670                        ; - the number of seconds and hundredths of a second that it takes to complete the transfer.
   671                        ; -  Note that the benchmark routines use a multiple block transfer of 64 blocks (32KB).
   672                        ;
   673                        ; The User is prompted for the Write function, as this overwrites a 32MB block of data on the
   674                        ; - IDE device, which results in a loss of data. When executing the Write benchmark, the
   675                        ; - LBA Buffer will be filled with a "55AA" pattern for a 512-byte block.
   676                        ;
   677                        ; Error checking is done after each LBA Read or Write function and any error will be
   678                        ; - displayed and the test aborted after that.
   679                        ;
   680 00:0BCC: A9 D2                        LDA     #<LBA_BENCH_INTRO       ;Get LBA Bench Intro Msg
   681 00:0BCE: A0 18                        LDY     #>LBA_BENCH_INTRO
   682 00:0BD0: 20 3F FF                     JSR     B_PROMPTR               ;Send to console
   683                        BENCH_IN_LP
   684 00:0BD3: 20 66 0F                     JSR     RDCHAR                  ;Get character from user
   685 00:0BD6: 20 21 FF                     JSR     B_CHROUT                ;Send to console
   686 00:0BD9: C9 52                        CMP     #"R"                    ;Test for Read
   687 00:0BDB: F0 09                        BEQ     IDE_BENCH_READ          ;If yes, go set RTC
   688 00:0BDD: C9 57                        CMP     #"W"                    ;Test for Write
   689 00:0BDF: F0 59                        BEQ     IDE_BENCH_WRITE         ;If no, skip RTC set
   690 00:0BE1: 20 70 0F                     JSR     BEEP                    ;Else, error, send beep
   691 00:0BE4: 80 ED                        BRA     BENCH_IN_LP             ;Branch back and try again
   692                        ;
