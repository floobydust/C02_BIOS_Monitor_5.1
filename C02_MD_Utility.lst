  1037 00:0D9A: A0 1C                        LDY     #>RAM_START_MSG         ;
  1038 00:0D9C: 20 3F FF                     JSR     B_PROMPTR               ;Send to Console
  1039 00:0D9F: 20 9E 0F                     JSR     HEXIN4                  ;Call Monitor routine
  1040                        ;
  1041 00:0DA2: A9 17                        LDA     #<BLK_SIZE_MSG          ;Get LBA count for xfer
  1042 00:0DA4: A0 1C                        LDY     #>BLK_SIZE_MSG          ;
  1043 00:0DA6: 20 3F FF                     JSR     B_PROMPTR               ;Send to Console
  1044                        ;
  1045 00:0DA9: 20 17 0F                     JSR     DECIN                   ;Get Decimal input, convert to BCD, then to HEX
  1046                        ;
  1047 00:0DAC: A6 14                        LDX     HEX6AND7                ;Get low byte (number of blocks)
  1048 00:0DAE: A5 A8                        LDA     INDEXL                  ;Get RAM address to start from
  1049 00:0DB0: A4 A9                        LDY     INDEXH                  ;
  1050 00:0DB2: 20 12 FF                     JSR     B_IDE_SET_ADDR          ;Call BIOS to set address and block count
  1051                        ;
  1052 00:0DB5: A9 81                        LDA     #<SYS_CONFIRM_MSG       ;Get Confirm Message for xfer
  1053 00:0DB7: A0 1C                        LDY     #>SYS_CONFIRM_MSG       ;
  1054 00:0DB9: 20 3F FF                     JSR     B_PROMPTR               ;Send to Console
  1055                        ;
  1056                        SYS_WRT_WARN_LP
  1057 00:0DBC: 20 66 0F                     JSR     RDCHAR                  ;Get character from user
  1058 00:0DBF: 20 21 FF                     JSR     B_CHROUT                ;Send to console
  1059 00:0DC2: C9 59                        CMP     #"Y"                    ;Test for yes
  1060 00:0DC4: F0 09                        BEQ     SYS_WRITE_GO            ;If yes, do write benchmark
  1061 00:0DC6: C9 4E                        CMP     #"N"                    ;Test for no
  1062 00:0DC8: F0 25                        BEQ     SYS_WRITE_ABORT         ;If no, skip write benchmark
  1063 00:0DCA: 20 70 0F                     JSR     BEEP                    ;Else, error, send beep
