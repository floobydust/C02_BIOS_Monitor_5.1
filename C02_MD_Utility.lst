   528                        LBA_BLK_UPDATE
   529                        ; This routine updates the LBA block number being read or written
   530                        ; - This routine is only used for the full read or write
   531                        ;
   532 00:0AD8: EE 5C 1D                     INC     LBA_LOW_WORD            ;Increment 32-bit word
   533 00:0ADB: D0 0D                        BNE     SKIP_BLK_UPDATE
   534 00:0ADD: EE 5D 1D                     INC     LBA_LOW_WORD+1
   535 00:0AE0: D0 08                        BNE     SKIP_BLK_UPDATE
   536 00:0AE2: EE 5E 1D                     INC     LBA_HIGH_WORD
   537 00:0AE5: D0 03                        BNE     SKIP_BLK_UPDATE
   538 00:0AE7: EE 5F 1D                     INC     LBA_HIGH_WORD+1
   539 00:0AEA: 60           SKIP_BLK_UPDATE RTS                             ;Return to caller
   540                        ;
   541                        LBA_LIMIT_CHK
   542 00:0AEB: AD 5F 1D                     LDA     LBA_HIGH_WORD+1         ;Get high order word
   543 00:0AEE: CD 3F 02                     CMP     LOAD_IDE+$03            ;Compare to Limit
   544 00:0AF1: D0 1A                        BNE     LIMIT_GOOD              ;If not, exit
   545 00:0AF3: AD 5E 1D                     LDA     LBA_HIGH_WORD           ;Get high order word
   546 00:0AF6: CD 3E 02                     CMP     LOAD_IDE+$02            ;Compare to limit
   547 00:0AF9: D0 12                        BNE     LIMIT_GOOD              ;If not, exit
   548 00:0AFB: AD 5D 1D                     LDA     LBA_LOW_WORD+1          ;Get low order word
   549 00:0AFE: CD 3D 02                     CMP     LOAD_IDE+$01            ;Compare to limit
   550 00:0B01: D0 0A                        BNE     LIMIT_GOOD              ;If not, exit
   551 00:0B03: AD 5C 1D                     LDA     LBA_LOW_WORD            ;Get low order word
   552 00:0B06: CD 3C 02                     CMP     LOAD_IDE+$00            ;Compare to limit
   553 00:0B09: D0 02                        BNE     LIMIT_GOOD
   554 00:0B0B: 38                           SEC                             ;Set carry for limit reached
   555 00:0B0C: 60                           RTS
   556 00:0B0D: 18           LIMIT_GOOD      CLC                             ;Clear carry for limit good
   557 00:0B0E: 60                           RTS                             ;Return to caller
