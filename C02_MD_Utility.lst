    68                        ;**************************************************************************************************
    69             00000103   PEM             .EQU    $0103   ;PEM Entry
    70                        ;**************************************************************************************************
    71                        ;
    72                        ;       User program code can start here. Default to TEA of $0800, can be chaged as required
    73                        ;
    74                        ;**************************************************************************************************
    75                        ;
    76                                .ORG    $0800                           ;Start of User RAM for programs
    77                        ;
    78                        ; First, send an intro message to the console, Utility name and version.
    79                        ; Second, send the User Menu to the console, then enter Command mode.
    80                        ;
    81                        START
    82 00:0800: A9 8E                        LDA     #<INTRO_MSG             ;Load Message address
    83 00:0802: A0 10                        LDY     #>INTRO_MSG             ;into A/Y Regs
    84 00:0804: 20 3F FF                     JSR     B_PROMPTR               ;Call Monitor routine
    85                        MENU_LOOP
    86 00:0807: A9 00                        LDA     #<MENU_MSG              ;Load Menu address
    87 00:0809: A0 11                        LDY     #>MENU_MSG              ;into A/Y Regs
    88 00:080B: 20 3F FF                     JSR     B_PROMPTR               ;Call Monitor routine
    89                        ;
    90                        MAIN_LOOP
    91 00:080E: 20 66 0F                     JSR     RDCHAR                  ;Wait for keystroke (converts to upper-case)
    92 00:0811: A2 08                        LDX     #MONTAB-MONCMD-1        ;Get command list count
    93 00:0813: DD 2D 08     CMD_LP          CMP     MONCMD,X                ;Compare to command list
    94 00:0816: D0 0D                        BNE     CMD_DEC                 ;Check for next command and loop
    95 00:0818: 48                           PHA                             ;Save keystroke
    96 00:0819: 8A                           TXA                             ;Xfer Command index to A reg
    97 00:081A: 0A                           ASL     A                       ;Multiply keystroke value by 2 (command offset)
    98 00:081B: AA                           TAX                             ;Xfer Command offsett address to table MONTAB
    99 00:081C: 68                           PLA                             ;Restore keystroke (some commands send to terminal)
   100 00:081D: 20 22 08                     JSR     DOCMD                   ;Call Monitor command processor as a subroutine
   101 00:0820: 80 E5                        BRA     MENU_LOOP               ;Command processed, branch/wait for next command
   102 00:0822: 7C 36 08     DOCMD           JMP     (MONTAB,X)              ;Execute command from Table
   103                        ;
   104 00:0825: CA           CMD_DEC         DEX                             ;Decrement index count
   105 00:0826: 10 EB                        BPL     CMD_LP                  ;If more to check, loop back
   106 00:0828: 20 70 0F                     JSR     BEEP                    ;Beep for error, not valid command character
   107 00:082B: 80 E1                        BRA     MAIN_LOOP               ;Branch back and re-enter Monitor
   108                        ;
   109                        ; Command Code List
   110                        ;
   111                        MONCMD
   112 00:082D: 31                   .DB     "1"                             ;Identify MicroDrive and display
   113 00:082E: 32                   .DB     "2"                             ;Read LBA and display
   114 00:082F: 33                   .DB     "3"                             ;Write LBA and verify
   115 00:0830: 34                   .DB     "4"                             ;Sequential Read of all LBA
   116 00:0831: 35                   .DB     "5"                             ;Sequential Write of all LBA
   117 00:0832: 36                   .DB     "6"                             ;Benchmark MicroDrive Read/Write
   118 00:0833: 4D                   .DB     "M"                             ;Menu display
   119 00:0834: 53                   .DB     "S"                             ;System Transfer RAM to Disc
   120 00:0835: 51                   .DB     "Q"                             ;Quit Utility
   121                        MONTAB
   122 00:0836: F0 08                .DW     IDE_IDENTIFY                    ;Address of IDE Identify routine
   123 00:0838: 68 09                .DW     IDE_READ_LBA                    ;Address of IDE Read/Display LBA
   124 00:083A: F0 09                .DW     IDE_WRITE_LBA                   ;Address of IDE Write/Verify LBA
   125 00:083C: 2D 0A                .DW     IDE_SEQ_READ                    ;Address of Sequential LBA Read
  Fri Apr 24 2026  6:57                                                                                                    Page 11


   126 00:083E: 0F 0B                .DW     IDE_SEQ_WRITE                   ;Address of Sequential LBA Write
   127 00:0840: CC 0B                .DW     IDE_BENCHMARK                   ;Address of IDE Benchmark
   128 00:0842: 07 08                .DW     MENU_LOOP                       ;Address of Main Menu
   129 00:0844: 87 0D                .DW     SYS_XFER                        ;Address of System Transfer
   130 00:0846: B6 0C                .DW     QUIT                            ;Address of Quit Utility
   131                        ;
   132                        ;[D] HEX/TEXT DUMP command:
   133                        ; Display in HEX followed by TEXT, the contents of 256 consecutive memory addresses
   134                        ;
   135                        DUMP
   136 00:0848: 8E 5B 1D                     STX     ROWS                    ;Save Row count
   137 00:084B: 64 AA                        STZ     TEMP1L                  ;Clear Offset to data
   138 00:084D: 64 AB                        STZ     TEMP1H                  ;used for showing loaded data from device
   139                        ;
   140 00:084F: 20 8A 0F     LINED           JSR     CROUT                   ;
   141 00:0852: 20 A4 08                     JSR     DMPGR                   ;Send address offsets to terminal
   142 00:0855: 20 D4 08                     JSR     GLINE                   ;Send horizontal line to terminal
   143 00:0858: 20 8A 0F                     JSR     CROUT                   ;Send CR,LF to terminal
   144 00:085B: AE 5B 1D                     LDX     ROWS                    ;Set line count for rows displayed
   145 00:085E: 20 75 0F     DLINE           JSR     SPC                     ;Send 4 Spaces to terminal
   146 00:0861: 20 75 0F                     JSR     SPC
   147 00:0864: 20 75 0F                     JSR     SPC
   148 00:0867: 20 75 0F                     JSR     SPC
   149 00:086A: 20 DF 08                     JSR     PROFFSET                ;Print INDEX value
   150 00:086D: 20 75 0F                     JSR     SPC                     ;Send 2 Spaces to terminal
   151 00:0870: 20 75 0F                     JSR     SPC
   152 00:0873: A0 00                        LDY     #$00                    ;Initialize line byte counter
   153                        GETBYT
   154 00:0875: B2 A8                        LDA     (INDEXL)
   155 00:0877: 99 40 02                     STA     SRCHBUFF,Y              ;Save in Search buffer (16 bytes)
   156 00:087A: 20 52 10                     JSR     PRBYTE                  ;Display byte as a HEX value
   157 00:087D: 20 75 0F                     JSR     SPC                     ;Send Space to terminal
   158 00:0880: 20 97 0F                     JSR     INCINDEX                ;Increment Index to next byte location
   159 00:0883: 20 E9 08                     JSR     INCOFFSET               ;Increment Offset address
   160 00:0886: C8                           INY                             ;Increment index
   161 00:0887: C0 10                        CPY     #$10                    ;Check for all 16
   162 00:0889: D0 EA                        BNE     GETBYT                  ;Loop back until 16 bytes have been displayed
   163 00:088B: 20 75 0F                     JSR     SPC                     ;Send a space
   164 00:088E: A0 00                        LDY     #$00                    ;Reset index for SRCHBUFF
   165 00:0890: B9 40 02     GETBYT2         LDA     SRCHBUFF,Y              ;Get buffered line (16 bytes)
   166 00:0893: 20 45 10                     JSR     PRASC                   ;Print ASCII character
   167 00:0896: C8                           INY                             ;Increment index to next byte
   168 00:0897: C0 10                        CPY     #$10                    ;Check for 16 bytes
   169 00:0899: D0 F5                        BNE     GETBYT2                 ;Loop back until 16 bytes have been displayed
   170 00:089B: 20 8A 0F                     JSR     CROUT                   ;Else, send CR,LF to terminal
   171 00:089E: CA                           DEX                             ;Decrement line count
   172 00:089F: D0 BD                        BNE     DLINE                   ;Branch back until all rows done
   173 00:08A1: 20 D4 08                     JSR     GLINE                   ;Send horizontal line to terminal
   174                        ;
   175                        ;DMPGR subroutine: Send address offsets to terminal
   176                        ;
   177 00:08A4: A9 01        DMPGR           LDA     #<SYS_ADDR_MSG          ;Get " addr:" msg
   178 00:08A6: A0 1D                        LDY     #>SYS_ADDR_MSG          ;
   179 00:08A8: 20 3F FF                     JSR     B_PROMPTR               ;Send to terminal
   180 00:08AB: 20 75 0F                     JSR     SPC                     ;Add two additional spaces
   181 00:08AE: 20 75 0F                     JSR     SPC
   182 00:08B1: A2 00                        LDX     #$00                    ;Zero index count
   183 00:08B3: 8A           MDLOOP          TXA                             ;Send "00" - "0F", separated by 1 Space to terminal
   184 00:08B4: 20 52 10                     JSR     PRBYTE                  ;Print byte value
   185 00:08B7: 20 75 0F                     JSR     SPC                     ;Add a space
   186 00:08BA: E8                           INX                             ;Increment the count
   187 00:08BB: E0 10                        CPX     #$10                    ;Check for 16
   188 00:08BD: D0 F4                        BNE     MDLOOP                  ;Loop back until done
  Fri Apr 24 2026  6:57                                                                                                    Page 12


   189                        ;
   190                        ;Print the ASCII text header "0123456789ABCDEF"
   191                        ;
   192 00:08BF: 20 75 0F                     JSR     SPC                     ;Send a space
   193 00:08C2: A2 00                        LDX     #$00                    ;Zero X reg for "0"
   194 00:08C4: 8A           MTLOOP          TXA                             ;Xfer to A reg
   195 00:08C5: 20 30 10                     JSR     BIN2ASC                 ;Convert Byte to two ASCII digits
   196 00:08C8: 98                           TYA                             ;Xfer the low nibble character to A reg
   197 00:08C9: 20 21 FF                     JSR     B_CHROUT                ;Send least significant HEX to terminal
   198 00:08CC: E8                           INX                             ;Increment to next HEX character
   199 00:08CD: E0 10                        CPX     #$10                    ;Check for 16
   200 00:08CF: D0 F3                        BNE     MTLOOP                  ;Branch back till done
   201 00:08D1: 4C 8A 0F                     JMP     CROUT                   ;Do a CR/LF and return
   202                        ;
   203                        ;GLINE subroutine: Send a horizontal line to console used by memory display only.
   204                        ;
   205 00:08D4: A2 4F        GLINE           LDX     #$4F                    ;Load index for 79 decimal
   206 00:08D6: A9 7E                        LDA     #$7E                    ;Get "~" character
   207 00:08D8: 20 21 FF     GLINEL          JSR     B_CHROUT                ;Send to terminal (draw a line)
   208 00:08DB: CA                           DEX                             ;Decrement count
   209 00:08DC: D0 FA                        BNE     GLINEL                  ;Branch back until done
   210 00:08DE: 60                           RTS                             ;Return to caller
   211                        ;
   212                        ;PRINT Offset subroutine: Prints a $ sign followed by TEMP1L/H
   213                        ;
   214 00:08DF: 20 85 0F     PROFFSET        JSR     DOLLAR                  ;Print a $ sign
   215 00:08E2: A5 AA                        LDA     TEMP1L                  ;Get Index Low byte
   216 00:08E4: A4 AB                        LDY     TEMP1H                  ;Get Index High byte
   217 00:08E6: 4C 68 10                     JMP     PRWORD                  ;Print Word, return
   218                        ;
   219                        ;Increment Data offset to display
   220                        ;
   221                        INCOFFSET
   222 00:08E9: E6 AA                        INC     TEMP1L                  ;Increment low byte
   223 00:08EB: D0 02                        BNE     SK_HIOFF                ;If not equal, skip high byte
   224 00:08ED: E6 AB                        INC     TEMP1H                  ;Increment high byte
   225 00:08EF: 60           SK_HIOFF        RTS                             ;Return to caller
   226                        ;
   227                        ; MicroDrive Routines
   228                        ;
   229                        IDE_IDENTIFY
   230                        ; Uses the BIOS call to load drive identity information.
   231                        ; This routine will display the following information from the ID block:
   232                        ;
   233                        ;       Bytes $36 - $5D       Model Number:
   234                        ;       Bytes $14 - $27       Serial Number:
   235                        ;       Bytes $2E - $35       Firmware Revision:
   236                        ;       Bytes $62 - $63       LBA Mode Support:
   237                        ;       Bytes $78 - $7B       Total LBA Count:
   238                        ;
   239                        ; The above data is in Big Endian format or ASCII format
   240                        ;
   241 00:08F0: 20 06 FF                     JSR     B_IDE_IDENTIFY          ;Call BIOS routine
   242 00:08F3: 20 61 0D                     JSR     SWAP_BYTE               ;Swap High/Low Bytes
   243                        ;
   244 00:08F6: A9 D0                        LDA     #<DRIVE_IDENTITY        ;Get low order offset
   245 00:08F8: A0 15                        LDY     #>DRIVE_IDENTITY        ;Get high order offset
   246 00:08FA: 20 3F FF                     JSR     B_PROMPTR               ;Send message to console
   247                        ;
   248                        ;ID Block now loaded into buffer
   249                        ; Next, print the description message, then print the offset to the ID block
   250                        ; for ASCII text, but will need to do some transforms for Mode Support and
   251                        ; LBA block count.
  Fri Apr 24 2026  6:57                                                                                                    Page 13


   252                        ;
