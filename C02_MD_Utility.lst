  1615 00:107E: F0 0D                        BEQ     DOCONT                  ;If yes, continue/exit
  1616 00:1080: C9 4E                        CMP     #$4E                    ;If "N", quit/exit
  1617 00:1082: F0 05                        BEQ     DONTCNT                 ;Return if not ESC
  1618 00:1084: 20 70 0F                     JSR     BEEP                    ;Send Beep to console
  1619 00:1087: 80 F0                        BRA     TRY_AGN                 ;Loop back, try again
  1620 00:1089: 68           DONTCNT         PLA                             ;Else remove return address
  1621 00:108A: 68                           PLA                             ;and discard it
  1622 00:108B: 64 B8                        STZ     CMDFLAG                 ;Clear all bits in command flag
  1623 00:108D: 60           DOCONT          RTS                             ;Return
