  1091                        ; The following routines are borrowed from Brian Phelps' SyMON monitor.
  1092                        ; - HEXTOBCD, BCDOUT, BCDTOASC, BCDTOHEX, ASCTODEC
  1093                        ; - These have been rewritten to use CMOS instructions, etc.
  1094                        ;
  1095                        ;HEXTOBCD subroutine: convert a 1-8 digit HEX value to a 1-10 digit BCD value.
  1096                        ; Call with 8 digit (4 byte) HEX value in HEX0AND1(MSB) through HEX6AND7(LSB).
  1097                        ; Returns with 10 digit (5 byte) BCD result in DEC0AND1(MSB) through DEC8AND9(LSB)
  1098                        ;HPHANTOM is a 16 bit address used to reference an 8 bit zero-page address.
  1099                        ; (HEXTOBCD needs LDA $hh,Y (an invalid instruction) so we use LDA $00hh,Y instead)
  1100                        ; This address is not written-to nor read-from in the HEXTOBCD subroutine.
  1101                        ; The address is the zero-page memory location immediatly below the HEX0AND1 variable
  1102                        ;HEX value input buffer:
  1103                        ;HEX0AND1 Two most significant HEX digits
  1104                        ;HEX2AND3
  1105                        ;HEX4AND5
  1106                        ;HEX6AND7 Two least significant HEX digits
  1107                        ;BCD value output buffer (BCD accumulator):
  1108                        ;DEC0AND1 ;Two most significant BCD digits
  1109                        ;DEC2AND3
  1110                        ;DEC4AND5
  1111                        ;DEC6AND7
  1112                        ;DEC8AND9 ;Two least significant BCD digits
  1113                        ;
  1114 00:0DF2: 64 15        HEXTOBCD        STZ     DEC0AND1                ;Init (zero) buffer
  1115 00:0DF4: 64 16                        STZ     DEC2AND3
  1116 00:0DF6: 64 17                        STZ     DEC4AND5
  1117 00:0DF8: 64 18                        STZ     DEC6AND7
  1118 00:0DFA: 64 19                        STZ     DEC8AND9
  1119 00:0DFC: A0 04                        LDY     #$04                    ;Initialize HEX input buffer byte index: point to addre
                    ss minus 1 of LSB
  1120 00:0DFE: A2 04                        LDX     #$04                    ;Initialize multiplicand table index: point to LSB of l
                    owest multiplicand
  1121 00:0E00: B9 10 00     DECLOOP         LDA     HPHANTOM,Y              ;Read indexed byte from input buffer: Y REGISTER index 
                    always > 0 here
  1122 00:0E03: 29 0F                        AND     #$0F                    ;Zero the high digit
  1123 00:0E05: 20 20 0E                     JSR     MULTIPLY                ;Multiply low digit
  1124 00:0E08: E8                           INX                             ;Add 5 to multiplicand table index: point to LSB of nex
                    t higher multiplicand
  1125 00:0E09: E8                           INX
  1126 00:0E0A: E8                           INX
  1127 00:0E0B: E8                           INX
  1128 00:0E0C: E8                           INX
